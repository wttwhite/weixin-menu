.form-page {
  min-height: 100vh;
  padding: 40rpx 28rpx;
}

.form-card {
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.form-title {
  font-size: 42rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-text {
  margin-top: 16rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.field-wrap {
  margin-top: 36rpx;
  --td-input-label-color: var(--text-secondary);
  --td-input-placeholder-color: #c0aba0;
  --td-input-border-bottom-color: var(--border-soft, #e8ddd4);
}

.submit-btn {
  margin-top: 40rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
  --td-button-primary-active-border-color: var(--brand-strong);
}
