<view class="form-page">
  <view class="form-card">
    <view class="form-title">创建一个新的菜单空间</view>
    <view class="form-text">适合家庭、合租、团队厨房等场景。创建后会自动切换到新空间。</view>

    <view class="field-label">空间名称</view>
    <input
      class="field-input"
      placeholder="例如：白塔路小分队"
      value="{{name}}"
      bindinput="handleNameInput"
    />

    <button class="submit-button" loading="{{submitting}}" bindtap="submit">创建并进入</button>
  </view>
</view>
