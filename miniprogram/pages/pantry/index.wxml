<view class="pantry-page" style="{{themeStyle}}">
  <view class="hero-banner">
    <image class="hero-banner__background" src="/images/food-hero.svg" mode="aspectFill" />
    <view class="hero-banner__overlay">
      <view class="hero-banner__date">{{currentDateLabel}}</view>
    </view>
  </view>

  <view class="management-card">
    <view class="management-card__top">
      <view class="management-card__cover">{{managementCoverText}}</view>

      <view class="management-card__meta">
        <view class="management-card__title">库存管理</view>
        <view class="management-card__count">{{managementCountText}}</view>
        <view class="management-card__summary">{{managementStatusText}}</view>
      </view>

      <view class="management-card__more" bindtap="openSettingsModal">⋮</view>
    </view>

    <view class="management-card__actions">
      <t-button class="action-pill" theme="primary" shape="round" bindtap="goCreate">＋ 添加库存</t-button>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>
  <view wx:if="{{!errorMessage && truncationMessage}}" class="feedback-card">{{truncationMessage}}</view>

  <view wx:if="{{!activeSpaceId}}" class="empty-card">
    <view class="empty-card__title">先选择一个空间</view>
    <view class="empty-card__text">空间用于团队共享库存、菜谱、计划和采购数据。</view>
    <t-button class="empty-card__button" theme="primary" block bindtap="openSpace">前往选择空间</t-button>
  </view>

  <view wx:else class="pantry-body">
    <view class="search-card">
      <view class="search-card__row">
        <view class="search-box">
          <view class="search-box__icon">⌕</view>
          <input
            class="search-box__input"
            value="{{searchKeyword}}"
            placeholder="搜索食材、分类、位置"
            placeholder-class="search-box__placeholder"
            bindinput="handleSearchInput"
            confirm-type="search"
          />
          <view wx:if="{{searchKeyword}}" class="search-box__clear" bindtap="clearSearch">×</view>
        </view>

        <view class="processed-toggle" bindtap="handleToggleProcessed">{{showProcessedText}}</view>
      </view>
    </view>

    <view class="channel-layout">
      <view class="channel-rail">
        <scroll-view class="channel-rail__scroll" scroll-y="true" show-scrollbar="{{false}}" style="height:{{railScrollHeight}}px">
          <view class="channel-rail__inner">
            <view
              wx:for="{{categoryViewItems}}"
              wx:key="key"
              class="{{item.itemClass}}"
              data-key="{{item.key}}"
              bindtap="handleCategoryChange"
            >
              <view class="rail-item__content">
                <view class="rail-item__label">{{item.label}}</view>
                <view class="rail-item__count">{{item.countText}}</view>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="channel-column">
        <view class="surface-head">
          <view>
            <view class="surface-eyebrow">共享库存</view>
            <view class="surface-title">{{activeCategoryLabel}}</view>
          </view>
          <view class="surface-meta">{{visibleItemsCountText}}</view>
        </view>

        <view class="surface-subtitle">{{summary}}</view>

        <view class="channel-surface">
          <scroll-view class="channel-surface__scroll" scroll-y="{{showVisibleItems}}" show-scrollbar="{{false}}" bindscroll="handleSurfaceScroll" style="height:{{surfaceScrollHeight}}px">
          <view wx:if="{{!errorMessage && loading}}" class="feedback-card feedback-card--inline">正在加载库存...</view>

          <view wx:elif="{{showVisibleItems}}" class="pantry-list">
            <view wx:for="{{visibleItems}}" wx:key="_id" class="pantry-item">
              <view class="pantry-item__main" data-pantry-item-id="{{item._id}}" bindtap="handleOpenItem">
                <view class="pantry-item__body">
                  <view class="pantry-item__header">
                    <view class="pantry-item__name">{{item.name}}</view>
                    <view class="{{item.usageStatusClass}}">{{item.usageStatusLabel}}</view>
                  </view>

                  <view class="pantry-item__meta">{{item.categoryLabel}} · {{item.locationLabel}}</view>
                  <view class="pantry-item__quantity">{{item.quantityDisplay}}</view>

                  <view class="pantry-item__footer">
                    <view wx:if="{{item.showStatusBadge}}" class="{{item.statusClass}}">{{item.statusLabel}}</view>
                    <view class="pantry-item__date">{{item.dateLabel}}</view>
                  </view>

                  <view wx:if="{{item.hasNotes}}" class="pantry-item__notes">{{item.notesDisplay}}</view>
                </view>
              </view>

              <view class="pantry-item__actions">
                <view
                  class="item-action item-action--status"
                  data-pantry-item-id="{{item._id}}"
                  catchtap="handleCycleUsageStatus"
                >
                  {{item.usageActionIcon}}
                </view>

                <view
                  class="item-action item-action--delete"
                  data-pantry-item-id="{{item._id}}"
                  catchtap="handleDeleteItem"
                >
                  {{item.deleteActionIcon}}
                </view>
              </view>
            </view>
          </view>

          <view wx:elif="{{showEmptyState}}" class="empty-card empty-card--inline">
            <view class="empty-card__title">{{emptyTitle}}</view>
            <view class="empty-card__text">{{emptyMessage}}</view>
            <t-button wx:if="{{!items.length}}" class="empty-card__button" theme="primary" block bindtap="goCreate">立即添加</t-button>
          </view>
        </scroll-view>
          <view wx:if="{{customScrollbarVisible}}" class="custom-scrollbar" style="height:{{customScrollbarThumbH}}px;top:{{customScrollbarThumbTop}}px"></view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showSettingsModal}}" class="settings-modal__overlay" catchtap="closeSettingsModal">
    <view class="settings-modal" catchtap="noop">
      <view class="settings-modal__header">
        <view class="settings-modal__title">库存配置</view>
        <view class="settings-modal__close" bindtap="closeSettingsModal">×</view>
      </view>

      <view class="settings-modal__content">
        <view class="settings-modal__section settings-modal__section--category">
          <view class="settings-modal__section-head">
            <view class="settings-modal__section-title">分类管理</view>
            <view class="settings-modal__section-meta">{{categoryManagerItems.length}} 类</view>
          </view>

          <view class="settings-modal__input-row">
            <input
              class="settings-modal__input"
              value="{{categoryManagerInput}}"
              placeholder="输入分类名称"
              bindinput="handleCategoryManagerInput"
            />
            <t-button class="settings-modal__confirm" theme="primary" size="small" bindtap="submitCategoryManagerCreate">确定</t-button>
          </view>

          <view wx:if="{{categoryManagerLoading}}" class="settings-modal__hint">正在读取分类...</view>

          <view wx:elif="{{!categoryManagerViewItems.length}}" class="settings-modal__empty">
            <view class="settings-modal__empty-illustration">类</view>
            <view class="settings-modal__empty-title">暂无分类</view>
            <view class="settings-modal__empty-text">还没有维护库存分类，先添加一个常用分类。</view>
          </view>

          <scroll-view wx:else scroll-y="true" class="settings-modal__list">
            <view class="settings-modal__list-inner">
              <view wx:for="{{categoryManagerViewItems}}" wx:key="name" class="{{item.itemClass}}">
                <view
                  class="{{item.dragClass}}"
                  data-type="category"
                  data-index="{{index}}"
                  catchtouchstart="handleManagerDragStart"
                  catchtouchmove="handleManagerDragMove"
                  catchtouchend="handleManagerDragEnd"
                  catchtouchcancel="handleManagerDragCancel"
                >
                  ⋮⋮
                </view>
                <view class="settings-modal__name">{{item.name}}</view>
                <view class="settings-modal__actions">
                  <view class="settings-modal__edit" data-name="{{item.name}}" bindtap="renameCategoryManagerItem">✎</view>
                  <view wx:if="{{item.showCountBadge}}" class="settings-modal__count">{{item.countText}}</view>
                  <view
                    wx:elif="{{item.showDelete}}"
                    class="settings-modal__delete"
                    data-name="{{item.name}}"
                    data-deletable="{{item.deletable}}"
                    bindtap="deleteCategoryManagerItem"
                  >
                    ×
                  </view>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>

        <view class="settings-modal__section settings-modal__section--location">
          <view class="settings-modal__section-head">
            <view class="settings-modal__section-title">位置管理</view>
            <view class="settings-modal__section-meta">{{locationManagerItems.length}} 处</view>
          </view>

          <view class="settings-modal__input-row">
            <input
              class="settings-modal__input"
              value="{{locationManagerInput}}"
              placeholder="输入位置名称"
              bindinput="handleLocationManagerInput"
            />
            <t-button class="settings-modal__confirm" theme="primary" size="small" bindtap="submitLocationManagerCreate">确定</t-button>
          </view>

          <view wx:if="{{locationManagerLoading}}" class="settings-modal__hint">正在读取位置...</view>

          <view wx:elif="{{!locationManagerViewItems.length}}" class="settings-modal__empty">
            <view class="settings-modal__empty-illustration settings-modal__empty-illustration--location">位</view>
            <view class="settings-modal__empty-title">暂无位置</view>
            <view class="settings-modal__empty-text">还没有维护库存位置，先添加一个常用存放位置。</view>
          </view>

          <scroll-view wx:else scroll-y="true" class="settings-modal__list">
            <view class="settings-modal__list-inner">
              <view wx:for="{{locationManagerViewItems}}" wx:key="name" class="{{item.itemClass}}">
                <view
                  class="{{item.dragClass}}"
                  data-type="location"
                  data-index="{{index}}"
                  catchtouchstart="handleManagerDragStart"
                  catchtouchmove="handleManagerDragMove"
                  catchtouchend="handleManagerDragEnd"
                  catchtouchcancel="handleManagerDragCancel"
                >
                  ⋮⋮
                </view>
                <view class="settings-modal__name">{{item.name}}</view>
                <view class="settings-modal__actions">
                  <view class="settings-modal__edit" data-name="{{item.name}}" bindtap="renameLocationManagerItem">✎</view>
                  <view wx:if="{{item.showCountBadge}}" class="settings-modal__count">{{item.countText}}</view>
                  <view
                    wx:elif="{{item.showDelete}}"
                    class="settings-modal__delete"
                    data-name="{{item.name}}"
                    data-deletable="{{item.deletable}}"
                    bindtap="deleteLocationManagerItem"
                  >
                    ×
                  </view>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
  </view>

  <pantry-form-modal
    visible="{{showCreateModal}}"
    title="添加库存"
    submit-label="添加库存"
    submitting="{{submittingCreate}}"
    value="{{createForm}}"
    category-options="{{createCategoryOptions}}"
    location-options="{{createLocationOptions}}"
    bind:change="handleCreateFormChange"
    bind:close="closeCreateModal"
    bind:submit="submitCreatePantry"
  />
</view>
