page {
  height: 100%;
}

.pantry-page {
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 14rpx 18rpx calc(env(safe-area-inset-bottom) + 127rpx);
  overflow: hidden;
  background:
    radial-gradient(circle at top, rgba(135, 203, 158, 0.18), transparent 30%),
    linear-gradient(180deg, #f7faf8 0%, #edf2ef 100%);
}

.hero-banner {
  position: relative;
  height: 170rpx;
  overflow: hidden;
  border-radius: 34rpx;
  box-shadow: 0 28rpx 46rpx rgba(71, 52, 35, 0.12);
}

.hero-banner__background {
  width: 100%;
  height: 100%;
}

.hero-banner__overlay {
  position: absolute;
  left: 16rpx;
  top: 14rpx;
  z-index: 4;
}

.hero-banner__date {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.34);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.24);
}

.management-card {
  position: relative;
  z-index: 2;
  margin-top: -92rpx;
  border-radius: 36rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 26rpx 42rpx rgba(56, 63, 79, 0.12);
}

.management-card__top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.management-card__cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6dc57c, #2f8b37);
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 24rpx rgba(47, 139, 55, 0.26);
}

.management-card__meta {
  flex: 1;
  min-width: 0;
}

.management-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.management-card__count {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #2f8b37;
  font-weight: 700;
}

.management-card__summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a808d;
}

.management-card__summary--accent {
  color: #51606f;
}

.management-card__more {
  flex: none;
  width: auto;
  min-width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  margin: 0;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f4f5f8;
  color: #656d7a;
  font-size: 34rpx;
}

.management-card__actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.action-pill {
  flex: none;
  width: auto;
  margin: 0;
  padding: 0 28rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 26rpx rgba(56, 63, 79, 0.12);
}

.action-pill--space {
  background: #f2f5f3;
  color: #576272;
}

.action-pill--create {
  background: linear-gradient(135deg, #3c9844, #2d7f34);
  color: #fff;
}

.feedback-card,
.empty-card,
.search-card {
  margin-top: 18rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 34rpx rgba(56, 63, 79, 0.1);
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.feedback-card--error {
  color: #8c2f2f;
}

.feedback-card--inline {
  margin-top: 12rpx;
  box-shadow: none;
  background: #f6f8fb;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #27323f;
}

.empty-card__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7a808d;
}

.empty-card__button {
  margin-top: 20rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #3c9844, #2d7f34);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-card--inline {
  margin-top: 12rpx;
  box-shadow: none;
  background: #fff;
}

.search-card__row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 18rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: #f4f6f8;
}

.search-box__icon,
.search-box__clear {
  color: #8c94a2;
  font-size: 28rpx;
}

.search-box__input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  font-size: 26rpx;
  color: #27323f;
}

.search-box__placeholder {
  color: #9ba3af;
}

.processed-toggle {
  flex: none;
  padding: 0 24rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #4d7edc;
  font-size: 24rpx;
  font-weight: 700;
}

.channel-layout {
  display: flex;
  flex: 1;
  min-height: 0;
  gap: 16rpx;
  margin-top: 18rpx;
  align-items: stretch;
  overflow: hidden;
}

.channel-rail {
  display: flex;
  flex-direction: column;
  width: 138rpx;
  min-width: 138rpx;
  align-self: stretch;
  border-radius: 34rpx;
  background: rgba(231, 238, 234, 0.96);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.56);
  overflow: hidden;
}

.channel-rail__scroll {
  flex: 1;
  height: 100%;
  min-height: 0;
}

.channel-rail__inner {
  padding: 14rpx 10rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.rail-item {
  width: 100%;
  box-sizing: border-box;
  min-height: 102rpx;
  margin: 0;
  padding: 16rpx 10rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: transparent;
  color: #7a808d;
  text-align: center;
}

.rail-item--active {
  background: #fff;
  color: #2f8b37;
  box-shadow: 0 14rpx 24rpx rgba(102, 114, 138, 0.14);
}

.rail-item__label {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.channel-surface {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx;
  padding: 18rpx;
  background: rgba(246, 248, 252, 0.92);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

.channel-surface__scroll {
  flex: 1;
  min-height: 0;
  height: auto;
}

.surface-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.surface-eyebrow {
  font-size: 22rpx;
  color: #7a808d;
}

.surface-title {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.surface-meta {
  font-size: 22rpx;
  color: #7a808d;
}

.surface-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a808d;
}

.pantry-list {
  display: grid;
  gap: 16rpx;
  margin-top: 14rpx;
}

.pantry-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 16rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 30rpx rgba(102, 114, 138, 0.14);
}

.pantry-item__main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pantry-item__thumb {
  width: 120rpx;
  min-width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dff3e2, #bbebc3);
  color: #2f8b37;
  font-size: 42rpx;
  font-weight: 800;
}

.pantry-item__body {
  flex: 1;
  min-width: 0;
}

.pantry-item__header {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pantry-item__name {
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.pantry-item__meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a808d;
}

.pantry-item__quantity {
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 700;
  color: #2f8b37;
}

.pantry-item__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 10rpx;
}

.pantry-item__date {
  font-size: 20rpx;
  color: #8b95a3;
}

.pantry-item__notes {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #7a808d;
}

.pantry-item__actions {
  width: auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.freshness-badge,
.usage-badge,
.item-action {
  width: auto;
  margin: 0;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
}

.freshness-badge,
.usage-badge {
  min-height: 42rpx;
  line-height: 42rpx;
}

.freshness-badge--fresh {
  background: #edf8ee;
  color: #2f8b37;
}

.freshness-badge--expiring-soon {
  background: #fff4de;
  color: #d6861d;
}

.freshness-badge--expired {
  background: #ffe8e8;
  color: #d14b4b;
}

.usage-badge--normal {
  background: #f3f5f8;
  color: #667084;
}

.usage-badge--opened {
  background: #eef5ff;
  color: #4d7edc;
}

.usage-badge--used-up {
  background: #fff2da;
  color: #b87517;
}

.usage-badge--discarded {
  background: #ffe8e8;
  color: #d14b4b;
}

.item-action {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0;
  font-size: 28rpx;
  box-shadow: 0 12rpx 18rpx rgba(102, 114, 138, 0.14);
  white-space: nowrap;
}

.item-action--status {
  background: linear-gradient(135deg, #5c98ff, #3f73d8);
  color: #fff;
}

.item-action--delete {
  background: #ffe8e8;
  color: #d14b4b;
}

.settings-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  padding: 120rpx 24rpx calc(env(safe-area-inset-bottom) + 150rpx);
  background: rgba(15, 23, 42, 0.24);
  backdrop-filter: blur(6rpx);
  box-sizing: border-box;
}

.settings-modal {
  height: 78vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 26rpx 42rpx rgba(37, 49, 71, 0.18);
}

.settings-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-modal__title {
  font-size: 44rpx;
  font-weight: 800;
  color: #182234;
}

.settings-modal__close,
.settings-modal__edit,
.settings-modal__delete,
.settings-modal__drag {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-modal__close,
.settings-modal__drag {
  background: #f2f4f8;
  color: #7a808d;
  transition: transform 160ms ease, background-color 160ms ease, color 160ms ease;
}

.settings-modal__content {
  flex: 1;
  min-height: 0;
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.settings-modal__section {
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fbfcfe;
  border: 1px solid #edf1f5;
}

.settings-modal__section--category {
  flex: 2;
}

.settings-modal__section--location {
  flex: 1;
  min-height: 70rpx;
}

.settings-modal__section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-modal__section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #27323f;
}

.settings-modal__section-meta {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #4d7edc;
  font-size: 22rpx;
  font-weight: 700;
}

.settings-modal__input-row {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.settings-modal__input {
  flex: 1;
  height: 44px;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1px solid #edf0f4;
  background: #fff;
  font-size: 28rpx;
}

.settings-modal__confirm {
  flex: none;
  width: 92rpx;
  max-width: 92rpx;
  min-width: 0;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 18rpx;
  background: #2f8b37;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.settings-modal__hint {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #7a808d;
}

.settings-modal__empty {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f7fafc, #eef4f8);
}

.settings-modal__empty-illustration {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6dc57c, #2f8b37);
  color: #fff;
  font-size: 46rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 26rpx rgba(47, 139, 55, 0.24);
}

.settings-modal__empty-illustration--location {
  background: linear-gradient(135deg, #7aa8ff, #4d7edc);
  box-shadow: 0 14rpx 26rpx rgba(77, 126, 220, 0.24);
}

.settings-modal__section--location .settings-modal__empty {
  min-height: 70rpx;
  gap: 6rpx;
  padding: 12rpx;
}

.settings-modal__section--location .settings-modal__empty-illustration {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
}

.settings-modal__section--location .settings-modal__empty-title {
  font-size: 24rpx;
}

.settings-modal__section--location .settings-modal__empty-text {
  font-size: 20rpx;
  line-height: 1.4;
}

.settings-modal__empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.settings-modal__empty-text {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7a808d;
  text-align: center;
}

.settings-modal__list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
}

.settings-modal__section--location .settings-modal__list {
  min-height: 70rpx;
}

.settings-modal__list-inner {
  display: grid;
  gap: 14rpx;
}

.settings-modal__item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: #fbfcfe;
  border: 1px solid #edf1f5;
  transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease;
}

.settings-modal__item--dragging {
  transform: translateX(10rpx) scale(1.02);
  background: linear-gradient(135deg, #f3fbf4, #ecf7ef);
  border-color: #b9ddbf;
  box-shadow: 0 16rpx 26rpx rgba(47, 139, 55, 0.18);
}

.settings-modal__drag--active {
  transform: scale(1.08);
  background: #e5f4e7;
  color: #2f8b37;
}

.settings-modal__name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #27323f;
}

.settings-modal__actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.settings-modal__edit {
  background: #eef5ff;
  color: #4d7edc;
}

.settings-modal__count {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f5f8;
  color: #8b95a3;
  font-size: 22rpx;
}

.settings-modal__delete {
  background: #ffe9e9;
  color: #d14b4b;
}
