.shopping-edit-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.card {
  border-radius: 30rpx;
  padding: 30rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.field {
  margin-top: 16rpx;
  --td-input-label-color: var(--text-secondary);
  --td-input-placeholder-color: #c0aba0;
  --td-input-border-bottom-color: var(--border-soft);
}

.inline-fields {
  display: flex;
  gap: 16rpx;
}

.inline-fields .field {
  flex: 1;
}

.submit-btn {
  margin-top: 30rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}
