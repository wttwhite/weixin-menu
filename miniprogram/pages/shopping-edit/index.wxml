<view class="shopping-edit-page">
  <view class="card">
    <view class="title">{{isEdit ? '编辑采购项' : '新增采购项'}}</view>

    <view class="field">
      <t-input
        label="名称"
        value="{{form.name}}"
        data-field="name"
        placeholder="例如：鸡蛋"
        bindinput="handleInput"
        clearable
      />
    </view>

    <view class="inline-fields">
      <view class="field">
        <t-input
          label="数量"
          value="{{form.quantity}}"
          data-field="quantity"
          placeholder="例如：2"
          bindinput="handleInput"
        />
      </view>
      <view class="field">
        <t-input
          label="单位"
          value="{{form.unit}}"
          data-field="unit"
          placeholder="例如：盒"
          bindinput="handleInput"
        />
      </view>
    </view>

    <view class="field">
      <t-textarea
        label="备注"
        value="{{form.notes}}"
        data-field="notes"
        maxlength="120"
        placeholder="可选"
        bindinput="handleInput"
      />
    </view>

    <t-button
      class="submit-btn"
      theme="primary"
      block
      loading="{{submitting}}"
      bindtap="submit"
    >
      {{isEdit ? '保存修改' : '添加采购项'}}
    </t-button>
  </view>
</view>
