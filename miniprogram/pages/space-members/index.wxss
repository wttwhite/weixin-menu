.members-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.members-hero {
  border-radius: 36rpx;
  padding: 40rpx 34rpx;
  background:
    linear-gradient(150deg, rgba(63, 58, 39, 0.95), rgba(121, 112, 76, 0.9)),
    var(--surface-strong);
  color: #fff;
  box-shadow: var(--shadow-soft);
}

.members-kicker {
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.74);
}

.members-title {
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 600;
}

.members-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.84);
}

.feedback-card,
.member-card,
.invite-card {
  margin-top: 24rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.feedback-card {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.feedback-card--error {
  color: #8c2f2f;
}

.members-list {
  display: grid;
  gap: 16rpx;
  margin-top: 24rpx;
}

.member-card {
  margin-top: 0;
}

.member-card__main {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.member-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.member-card__self {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-secondary);
}

.member-card__role {
  font-size: 24rpx;
  color: var(--brand-strong);
}

.member-card__remove {
  margin-top: 0;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.member-card__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.member-card__edit,
.member-card__remove {
  margin-top: 14rpx;
}

.member-card__edit {
  --td-button-outline-primary-color: var(--brand);
  --td-button-outline-primary-border-color: rgba(197, 106, 61, 0.36);
}

.member-card__remove {
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.invite-card__button {
  margin-top: 18rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.invite-card__title {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.invite-card__value {
  margin-top: 10rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}
