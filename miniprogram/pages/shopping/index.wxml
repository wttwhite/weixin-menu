<view class="shopping-page">
  <view class="shopping-hero">
    <view class="shopping-kicker">Shopping</view>
    <view class="shopping-title">{{activeSpaceId || '尚未选择空间'}}</view>
    <view class="shopping-text">{{summary}}</view>
    <view class="shopping-actions">
      <t-button class="shopping-btn shopping-btn--ghost" variant="outline" bindtap="openSpace">切换空间</t-button>
      <t-button class="shopping-btn" theme="primary" bindtap="createList">新建清单</t-button>
    </view>
  </view>

  <view wx:if="{{activeSpaceId && shoppingListOptions.length}}" class="list-picker-card">
    <picker range="{{shoppingListOptions}}" range-key="label" value="{{selectedShoppingListIndex}}" bindchange="handleShoppingListChange">
      <view class="list-picker-value">{{shoppingListOptions[selectedShoppingListIndex].label}}</view>
    </picker>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>
  <view wx:elif="{{loading}}" class="feedback-card">正在加载采购清单...</view>

  <view wx:elif="{{selectedShoppingList}}">
    <view class="toolbar-card">
      <t-button class="toolbar-btn" theme="primary" bindtap="goAddManualItem">手动添加</t-button>
      <t-button class="toolbar-btn toolbar-btn--outline" theme="primary" variant="outline" loading="{{generating}}" bindtap="generateFromMealPlans">从用餐计划生成</t-button>
    </view>

    <view wx:if="{{items.length}}" class="items-list">
      <view wx:for="{{items}}" wx:key="_id" class="item-card">
        <checkbox-group data-shopping-item-id="{{item._id}}" bindchange="handleToggleItem">
          <label class="item-main">
            <checkbox value="checked" checked="{{item.checked}}" />
            <view class="item-content">
              <view class="item-name {{item.checked ? 'item-name--checked' : ''}}">{{item.name}}</view>
              <view class="item-meta">
                <text wx:if="{{item.quantityLabel}}">{{item.quantityLabel}}</text>
                <text wx:if="{{item.sourceLabel}}" class="item-source">{{item.sourceLabel}}</text>
              </view>
              <view wx:if="{{item.notes}}" class="item-notes">{{item.notes}}</view>
            </view>
          </label>
        </checkbox-group>
        <t-button class="item-edit" theme="primary" variant="outline" size="small" data-shopping-item-id="{{item._id}}" bindtap="goEditItem">编辑</t-button>
      </view>
    </view>

    <view wx:else class="empty-card">
      <view class="empty-title">暂无采购项</view>
      <view class="empty-text">{{emptyMessage}}</view>
      <t-button class="empty-button" theme="primary" block bindtap="goAddManualItem">添加第一项</t-button>
    </view>
  </view>
</view>
