page {
  background: transparent;
}

.shopping-page {
  min-height: 100vh;
  padding: 20rpx 16rpx calc(env(safe-area-inset-bottom) + 127rpx);
}

.shopping-hero {
  border-radius: 34rpx;
  padding: 28rpx 24rpx 26rpx;
  background:
    radial-gradient(circle at 85% 18%, rgba(255, 255, 255, 0.24), transparent 16%),
    radial-gradient(circle at 88% 10%, rgba(255, 255, 255, 0.2), transparent 28%),
    linear-gradient(135deg, var(--brand, #4f7d8a) 0%, var(--brand-strong, #365e69) 100%);
  color: #fff;
  box-shadow: var(--shadow-soft, 0 20rpx 40rpx rgba(70, 110, 69, 0.2));
  overflow: hidden;
  position: relative;
}

.shopping-hero::before,
.shopping-hero::after {
  content: '';
  position: absolute;
  border-radius: 999rpx;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.shopping-hero::before {
  width: 220rpx;
  height: 220rpx;
  right: -40rpx;
  top: -30rpx;
}

.shopping-hero::after {
  width: 140rpx;
  height: 140rpx;
  right: 50rpx;
  top: 24rpx;
  border-style: dashed;
}

.shopping-hero__date,
.shopping-hero__eyebrow,
.shopping-hero__title-row,
.shopping-hero__text,
.shopping-hero__metrics {
  position: relative;
  z-index: 1;
}

.shopping-hero__date {
  font-size: 22rpx;
  opacity: 0.95;
}

.shopping-hero__eyebrow {
  margin-top: 8rpx;
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.76);
}

.shopping-hero__title-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.shopping-hero__icon {
  font-size: 38rpx;
  opacity: 0.92;
}

.shopping-hero__title {
  font-size: 52rpx;
  font-weight: 800;
}

.shopping-hero__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.shopping-hero__metrics {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
  padding: 22rpx 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.08);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(8rpx);
}

.shopping-hero__metric-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.shopping-hero__metric-value {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.feedback-card,
.empty-card {
  margin-top: 20rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: var(--surface-bg, rgba(255, 255, 255, 0.94));
  box-shadow: var(--shadow-soft, 0 18rpx 36rpx rgba(56, 63, 79, 0.08));
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary, #5e6673);
}

.feedback-card--error {
  color: var(--danger, #8c2f2f);
}

.shopping-status-tabs {
  margin-top: 18rpx;
  padding: 10rpx;
  border-radius: 999rpx;
  display: flex;
  gap: 8rpx;
  background: linear-gradient(135deg, var(--brand, #4f7d8a), var(--brand-strong, #365e69));
  box-shadow: var(--shadow-soft, 0 14rpx 30rpx rgba(70, 110, 69, 0.16));
}

.shopping-status-tab {
  flex: 1;
  min-width: 0;
  padding: 14rpx 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.74);
}

.shopping-status-tab--active {
  background: var(--surface-bg, #fff);
  color: var(--surface-strong, #3f3226);
  box-shadow: var(--shadow-soft, 0 12rpx 26rpx rgba(28, 49, 31, 0.12));
}

.shopping-status-tab__label {
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.shopping-status-tab__count {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.18);
}

.shopping-status-tab--active .shopping-status-tab__count {
  background: var(--surface-muted, rgba(76, 143, 73, 0.12));
}

.shopping-section-head {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.shopping-section-head__eyebrow {
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: var(--text-tertiary, #98a1ad);
}

.shopping-section-head__title {
  margin-top: 6rpx;
  font-size: 39rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--text-primary, #10203a);
}

.shopping-create-btn {
  flex: none;
  min-width: 168rpx;
  height: 70rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand, #4f7d8a), var(--brand-strong, #365e69));
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: var(--shadow-soft, 0 16rpx 26rpx rgba(47, 146, 58, 0.2));
  white-space: nowrap;
}

.shopping-list-grid {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.shopping-list-card {
  border-radius: 34rpx;
  padding: 24rpx;
  background: #fbfcfe;
  border: 2rpx solid rgba(56, 63, 79, 0.08);
  box-shadow: var(--shadow-soft, 0 18rpx 34rpx rgba(56, 63, 79, 0.08));
}

.shopping-list-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.shopping-list-card__main {
  flex: 1;
  min-width: 0;
  display: flex;
  gap: 16rpx;
}

.shopping-list-card__icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f8;
  color: var(--brand-strong, #617694);
  font-size: 42rpx;
}

.shopping-list-card__copy {
  flex: 1;
  min-width: 0;
}

.shopping-list-card__title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.shopping-list-card__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary, #16233a);
}

.shopping-list-card__status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.shopping-list-card__status--open {
  background: #dbeafe;
  color: #2563eb;
}

.shopping-list-card__status--completed {
  background: #dcfce7;
  color: #16803c;
}

.shopping-list-card__status--archived {
  background: #f4f5f8;
  color: #7a808d;
}

.shopping-list-card__date {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #c0c4cc;
}

.shopping-list-card__actions {
  display: grid;
  gap: 0;
}

.shopping-list-card__action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 0;
  box-shadow: none;
  background: transparent;
}

.shopping-list-card__action--edit {
  color: #606266;
}

.shopping-list-card__action--archive {
  color: #4b5563;
}

.shopping-list-card__action--danger {
  color: #f56c6c;
}

.shopping-list-card__element-icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
}

.shopping-list-card__element-edit-box {
  position: absolute;
  left: 3rpx;
  bottom: 4rpx;
  width: 30rpx;
  height: 30rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.shopping-list-card__element-edit-pencil {
  position: absolute;
  right: 8rpx;
  top: 16rpx;
  width: 27rpx;
  height: 9rpx;
  border-radius: 999rpx;
  border: 3rpx solid currentColor;
  background: #eef5ff;
  box-shadow: 0 0 0 3rpx #eef5ff;
  transform: rotate(-45deg);
  transform-origin: center;
  box-sizing: border-box;
}

.shopping-list-card__element-delete-handle {
  position: absolute;
  left: 15rpx;
  top: 9rpx;
  width: 14rpx;
  height: 8rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
  box-sizing: border-box;
}

.shopping-list-card__element-delete-lid {
  position: absolute;
  left: 8rpx;
  top: 17rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.shopping-list-card__element-delete-body {
  position: absolute;
  left: 10rpx;
  top: 18rpx;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.shopping-list-card__element-delete-line {
  display: none;
}

.shopping-list-card__element-archive-lid {
  position: absolute;
  left: 8rpx;
  top: 9rpx;
  width: 28rpx;
  height: 8rpx;
  border: 3rpx solid currentColor;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
  box-sizing: border-box;
}

.shopping-list-card__element-archive-body {
  position: absolute;
  left: 6rpx;
  top: 18rpx;
  width: 32rpx;
  height: 24rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.shopping-list-card__element-archive-line {
  position: absolute;
  left: 7rpx;
  top: 7rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.shopping-list-card__progress {
  margin-top: 18rpx;
}

.shopping-list-card__progress-track {
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #f4f5f8;
}

.shopping-list-card__progress-fill {
  height: 100%;
  border-radius: inherit;
}

.shopping-list-card__progress-fill--open {
  background: #3b82f6;
}

.shopping-list-card__progress-fill--completed {
  background: #22c55e;
}

.shopping-list-card__progress-fill--archived {
  background: #cbd5e1;
}

.shopping-list-card__progress-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #909399;
}

.shopping-list-card__subhead {
  margin-top: 22rpx;
  min-height: 64rpx;
  padding: 6rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.shopping-list-card__subhead-toggle {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.shopping-list-card__subhead-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary, #25314b);
}

.shopping-list-card__subhead-indicator {
  flex: none;
  font-size: 22rpx;
  font-weight: 700;
  color: #111827;
}

.shopping-list-card__generate {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #eef7ef);
  color: var(--success, #2f8b37);
  font-size: 22rpx;
  font-weight: 700;
}

.shopping-item-list {
  display: grid;
  gap: 12rpx;
  margin-top: 16rpx;
}

.shopping-item-list__generated-bar {
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  background: #fff3c4;
  color: #9a5d18;
  font-size: 25rpx;
  font-weight: 400;
}

.shopping-item-row {
  min-height: 80rpx;
  padding: 0 18rpx 0 12rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  background: #f9fafc;
}

.shopping-item-row checkbox {
  transform: scale(0.72);
  transform-origin: center;
}

.shopping-item-row__main {
  flex: 1;
  min-width: 0;
}

.shopping-item-row__checkline {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.shopping-item-row__content {
  flex: 1;
  min-width: 0;
}

.shopping-item-row__name {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-primary, #26354e);
}

.shopping-item-row__name--checked {
  color: #b8c0cc;
  text-decoration: line-through;
}

.shopping-item-row__quantity {
  flex: none;
  min-width: 64rpx;
  text-align: right;
  font-size: 24rpx;
  color: #7a808d;
}

.shopping-item-row__record {
  flex: none;
  min-width: 120rpx;
  height: 50rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #eaf5eb;
  color: #237542;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.shopping-item-row__record--checked {
  background: #f4f5f8;
  color: #a0a8b4;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary, #27323f);
}

.empty-card__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary, #7a808d);
}

.empty-card__button {
  margin-top: 22rpx;
  width: fit-content;
  min-width: 180rpx;
  height: 78rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand, #4f7d8a), var(--brand-strong, #365e69));
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.shopping-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 90rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(12, 24, 18, 0.28);
  backdrop-filter: blur(6rpx);
  box-sizing: border-box;
}

.shopping-modal {
  width: 100%;
  height: 100%;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 40rpx;
  padding: 26rpx 24rpx 24rpx;
  background: var(--surface-bg, rgba(255, 255, 255, 0.98));
  box-shadow: var(--shadow-soft, 0 24rpx 44rpx rgba(37, 49, 71, 0.18));
  box-sizing: border-box;
}

.shopping-modal--pantry {
  max-height: 86vh;
}

.shopping-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.shopping-modal__title {
  font-size: 34rpx;
  font-weight: 900;
  color: #1f2937;
}

.shopping-modal__close-icon {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f8;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
}

.category-selector__close {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f2f4f8);
  color: var(--text-secondary, #667084);
  font-size: 26rpx;
  font-weight: 700;
}

.shopping-modal__body {
  flex: 1;
  min-height: 0;
  height: auto;
  margin-top: 14rpx;
  overflow-y: auto;
}

.shopping-modal__body-content {
  padding-right: 4rpx;
  padding-bottom: 36rpx;
  box-sizing: border-box;
}

.shopping-modal__field-label,
.shopping-modal__subhead {
  margin-top: 20rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #374151;
}

.shopping-modal__input,
.shopping-modal__picker,
.shopping-modal__textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  border-radius: 18rpx;
  border: 1px solid var(--border-soft, #e8ecf2);
  background: var(--surface-bg, #fff);
  color: #27323f;
}

.shopping-modal__input,
.shopping-modal__picker {
  min-height: 88rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.shopping-modal__input--compact {
  min-height: 82rpx;
}

.shopping-modal__textarea {
  min-height: 66rpx;
  height: 66rpx;
  padding: 14rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.4;
}

.shopping-modal__divider {
  height: 1px;
  margin-top: 24rpx;
  background: var(--border-soft, #edf1f5);
}

.shopping-draft-row {
  margin-top: 18rpx;
}

.shopping-modal__grid,
.shopping-modal__picker-row,
.shopping-modal__footer {
  display: flex;
  gap: 12rpx;
}

.shopping-modal__footer {
  flex: none;
}

.shopping-draft-row__fields {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 58rpx;
  column-gap: 12rpx;
  row-gap: 16rpx;
  align-items: center;
}

.shopping-draft-row__input,
.shopping-draft-row__picker,
.shopping-modal__picker-field {
  flex: 1;
  min-width: 0;
}

.shopping-draft-row__input {
  height: 70rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1px solid var(--border-soft, #e7ebf1);
  background: var(--surface-bg, #fff);
  font-size: 26rpx;
  color: #27323f;
}

.shopping-draft-row__input--picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shopping-draft-row__input--placeholder {
  color: #9ca3af;
}

.shopping-draft-row__remove,
.shopping-modal__clear {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.shopping-draft-row__remove {
  grid-column: 3;
  grid-row: 1 / 3;
  align-self: center;
  justify-self: center;
  background: #ffe8e8;
  color: #d14b4b;
}

.shopping-modal__clear {
  margin-top: 12rpx;
  background: var(--surface-muted, #ffecec);
  color: var(--danger, #d14b4b);
}

.shopping-draft-row__quantity-stepper {
  height: 70rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1px solid var(--border-soft, #e7ebf1);
  background: var(--surface-bg, #fff);
  box-sizing: border-box;
}

.shopping-draft-row__stepper-btn {
  width: 72rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f4f5f8;
  color: #4b5563;
  font-size: 32rpx;
  font-weight: 700;
}

.shopping-draft-row__stepper-input {
  flex: 1;
  min-width: 0;
  height: 70rpx;
  text-align: center;
  font-size: 26rpx;
  color: #27323f;
}

.shopping-modal__add-row {
  margin-top: 18rpx;
  min-height: 74rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #e7f3e8);
  color: var(--brand, #4f7d8a);
  font-size: 28rpx;
  font-weight: 800;
}

.shopping-modal__close,
.shopping-modal__submit {
  min-height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.shopping-modal__close {
  width: 140rpx;
  background: #f4f5f8;
  color: #111827;
}

.shopping-modal__submit {
  flex: 1;
  background: linear-gradient(135deg, var(--brand, #4f7d8a), var(--brand-strong, #365e69));
  color: #fff;
}

.category-selector__overlay {
  position: fixed;
  inset: 0;
  z-index: 70;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(15, 23, 42, 0.22);
}

.category-selector {
  width: 100%;
  max-width: 640rpx;
  max-height: 62vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 42rpx rgba(37, 49, 71, 0.18);
  box-sizing: border-box;
}

.category-selector__header {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.category-selector__title {
  font-size: 34rpx;
  font-weight: 800;
  color: #182234;
}

.category-selector__list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  max-height: 52vh;
}

.category-selector__list-inner {
  display: grid;
  gap: 12rpx;
}

.category-selector__item {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #27323f;
  font-size: 32rpx;
  font-weight: 700;
}

.category-selector__item--active {
  background: var(--surface-muted, #f3f4f7);
  color: var(--brand);
}

.category-selector__empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #7a808d;
  font-size: 28rpx;
  text-align: center;
}

.shopping-modal__stepper {
  margin-top: 12rpx;
  min-height: 82rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  border: 1px solid var(--border-soft, #e7ebf1);
  background: var(--surface-bg, #fff);
}

.shopping-modal__stepper-btn {
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f4f6f9);
  color: var(--text-secondary, #5f6874);
  font-size: 34rpx;
}

.shopping-modal__stepper-value {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary, #25314b);
}
