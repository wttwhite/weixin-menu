.shopping-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.shopping-hero {
  border-radius: 36rpx;
  padding: 40rpx 34rpx;
  background:
    linear-gradient(150deg, rgba(35, 76, 84, 0.96), rgba(77, 127, 136, 0.9)),
    var(--surface-strong);
  color: #fff;
  box-shadow: var(--shadow-soft);
}

.shopping-kicker {
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.72);
}

.shopping-title {
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 600;
}

.shopping-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.84);
}

.shopping-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.shopping-btn {
  flex: 1;
  --td-button-primary-bg-color: #fff;
  --td-button-primary-color: #214850;
  --td-button-primary-border-color: #fff;
}

.shopping-btn--ghost {
  --td-button-outline-primary-color: rgba(255,255,255,0.9);
  --td-button-outline-primary-border-color: rgba(255, 255, 255, 0.4);
  --td-button-outline-primary-active-bg-color: rgba(255, 255, 255, 0.12);
}

.list-picker-card,
.feedback-card,
.toolbar-card,
.empty-card,
.item-card {
  margin-top: 24rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.list-picker-value {
  border-radius: 999rpx;
  background: #fff;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.feedback-card--error {
  color: #8c2f2f;
}

.toolbar-card {
  display: flex;
  gap: 16rpx;
}

.toolbar-btn {
  flex: 1;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.toolbar-btn--outline {
  --td-button-outline-primary-color: var(--brand);
  --td-button-outline-primary-border-color: var(--brand);
  --td-button-outline-primary-active-bg-color: rgba(197, 106, 61, 0.08);
}

.items-list {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
}

.item-card {
  margin-top: 0;
}

.item-main {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.item-content {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.item-name--checked {
  color: var(--text-secondary);
  text-decoration: line-through;
}

.item-meta {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.item-source {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(71, 128, 139, 0.12);
  color: #356a74;
}

.item-notes {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.item-edit {
  margin-top: 14rpx;
  --td-button-outline-primary-color: var(--brand);
  --td-button-outline-primary-border-color: rgba(199, 111, 68, 0.35);
  --td-button-outline-primary-active-bg-color: rgba(197, 106, 61, 0.06);
}

.empty-button {
  margin-top: 22rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
}

.empty-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}
