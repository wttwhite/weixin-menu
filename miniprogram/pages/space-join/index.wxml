<view class="form-page">
  <view class="form-card">
    <view class="form-title">使用邀请码加入空间</view>
    <view class="form-text">输入 6 位邀请码后，你会自动切换到对应空间。</view>

    <view class="field-wrap">
      <t-input
        label="邀请码"
        maxlength="6"
        placeholder="例如：AB12CD"
        value="{{inviteCode}}"
        bindinput="handleCodeInput"
        clearable
        custom-style="background: #fff; border-radius: 20rpx; letter-spacing: 8rpx; text-transform: uppercase;"
      />
    </view>

    <t-button
      class="submit-btn"
      theme="primary"
      block
      loading="{{submitting}}"
      bindtap="submit"
    >加入并进入</t-button>
  </view>
</view>
