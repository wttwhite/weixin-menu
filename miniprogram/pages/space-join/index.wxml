<view class="form-page">
  <view class="form-card">
    <view class="form-title">使用邀请码加入空间</view>
    <view class="form-text">输入 6 位邀请码后，你会自动切换到对应空间。</view>

    <view class="field-label">邀请码</view>
    <input
      class="field-input field-code"
      maxlength="6"
      placeholder="例如：AB12CD"
      value="{{inviteCode}}"
      bindinput="handleCodeInput"
    />

    <button class="submit-button" loading="{{submitting}}" bindtap="submit">加入并进入</button>
  </view>
</view>
