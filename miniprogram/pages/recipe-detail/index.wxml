<view class="detail-page" style="{{themeStyle}}">
  <view wx:if="{{loading}}" class="card">正在加载菜谱详情...</view>

  <view wx:elif="{{errorMessage}}" class="card card--error">
    <view class="card-title">加载失败</view>
    <view class="card-text">{{errorMessage}}</view>
    <t-button class="card-button" theme="primary" bindtap="goBack">返回</t-button>
  </view>

  <view wx:elif="{{item}}" class="detail-content">
    <view class="hero-card">
      <image class="hero-cover" src="{{coverImageUrl}}" mode="aspectFill" bindtap="previewImage" data-current="{{coverImageUrl}}" />
      <view class="hero-overlay">
        <view class="hero-copy-panel">
          <view wx:if="{{item.category}}" class="hero-badge">{{item.category}}</view>
          <view class="hero-title">{{item.name}}</view>
          <view wx:if="{{heroSummaryText}}" class="hero-summary">{{heroSummaryText}}</view>
          <view wx:if="{{heroMetricTexts.length}}" class="hero-metrics">
            <view wx:for="{{heroMetricTexts}}" wx:key="index" class="hero-metric">{{item}}</view>
          </view>
        </view>
      </view>
      <button class="hero-share" open-type="share">↗</button>
    </view>

    <view class="action-row">
      <t-button wx:if="{{canManageRecipe}}" t-class="action-btn action-btn--edit action-button action-button--edit" theme="primary" bindtap="goEdit">🖊 编辑</t-button>
      <t-button wx:if="{{canManageRecipe}}" t-class="action-btn action-btn--delete action-button action-button--delete" theme="danger" variant="outline" bindtap="removeRecipe">🗑 删除</t-button>
    </view>

    <view wx:if="{{hasIngredients}}" class="card">
      <view class="card-head">
        <view class="card-head__left">
          <view class="card-head__icon">🥬</view>
          <view class="card-title">食材列表</view>
        </view>
        <view class="card-head__meta">{{ingredientViewItems.length}} 项</view>
      </view>
      <view class="card-divider"></view>
      <view wx:for="{{ingredientViewItems}}" wx:key="displayIndex" class="ingredient-row">
        <view class="ingredient-row__num">{{item.displayIndex}}</view>
        <view class="ingredient-row__name">{{item.name}}</view>
        <view wx:if="{{item.hasAmountText}}" class="ingredient-row__amount">{{item.amountText}}</view>
      </view>
    </view>

    <view class="card">
      <view class="card-head">
        <view class="card-head__left">
          <view class="card-head__icon">👨‍🍳</view>
          <view class="card-title">制作步骤</view>
        </view>
        <view class="card-head__meta">{{stepViewItems.length}} 步</view>
      </view>
      <view class="card-divider"></view>
      <view wx:if="{{hasSteps}}">
        <view wx:for="{{stepViewItems}}" wx:key="displayIndex" class="step-panel">
          <view class="step-panel__title">步骤 {{item.displayIndex}}</view>
          <view class="step-panel__content">{{item.content}}</view>
        </view>
      </view>
      <view wx:else class="card-text">暂无步骤信息。</view>
    </view>

    <view wx:if="{{hasGalleryItems}}" class="card">
      <view class="card-head">
        <view class="card-head__left">
          <view class="card-head__icon">📷</view>
          <view class="card-title">菜谱图集</view>
        </view>
        <view class="card-head__meta">{{galleryItems.length}} 张</view>
      </view>
      <view class="card-divider"></view>
      <view class="gallery-grid">
        <view wx:for="{{galleryItems}}" wx:key="url" class="gallery-item {{item.isCover ? 'gallery-item--cover' : ''}}">
          <image
            class="gallery-image"
            src="{{item.url}}"
            mode="aspectFill"
            bindtap="previewImage"
            data-current="{{item.url}}"
          />
          <view wx:if="{{item.isCover}}" class="gallery-badge">封面</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{item && !loading && !errorMessage}}" class="bottom-actions">
    <t-button class="footer-close-btn footer-close-button" theme="default" block bindtap="goBack">关闭</t-button>
  </view>
</view>
