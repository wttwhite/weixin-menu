.detail-page {
  min-height: 100vh;
  padding: 20rpx 20rpx 160rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background:
    radial-gradient(circle at top, var(--surface-muted, #e8edf1), transparent 30%),
    linear-gradient(180deg, var(--page-bg, #f6f7f8) 0%, var(--surface-muted, #e8edf1) 100%);
}

.detail-content {
  display: grid;
  gap: 18rpx;
}

.hero-card,
.card {
  border-radius: 30rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 18rpx 30rpx rgba(56, 63, 79, 0.12);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 0;
  min-height: 360rpx;
}

.hero-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(11, 18, 32, 0.08) 0%, rgba(11, 18, 32, 0.48) 100%);
  pointer-events: none;
}

.hero-cover {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #f2f4f8;
  filter: saturate(0.94) brightness(0.88);
}

.hero-overlay {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  z-index: 1;
  color: #fff;
}

.hero-copy-panel {
  max-width: 88%;
  display: grid;
  gap: 10rpx;
  justify-items: start;
}

.hero-badge {
  display: inline-flex;
  justify-self: start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  align-self: start;
  background: rgba(14, 22, 38, 0.44);
  border: 1px solid rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  display: inline-flex;
  align-self: start;
  justify-self: start;
  width: auto;
  max-width: 100%;
  margin-top: 0;
  padding: 10rpx 16rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(10, 16, 28, 0.46);
  border: 1px solid rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 800;
  text-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.36);
}

.hero-summary {
  display: inline-flex;
  align-self: start;
  justify-self: start;
  width: auto;
  max-width: 100%;
  margin-top: 0;
  padding: 10rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(10, 16, 28, 0.42);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  text-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.28);
}

.hero-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 14rpx;
}

.hero-metric {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(12, 20, 34, 0.42);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  font-size: 28rpx;
  font-weight: 700;
  text-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.24);
}

button.hero-share {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 1;
  width: auto;
  min-width: 0;
  height: 68rpx;
  margin-left: 0;
  margin-right: 0;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border-radius: 34rpx;
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: none;
}

.action-row {
  display: flex;
  gap: 14rpx;
}

.t-button.action-btn {
  flex: 1;
  width: auto;
  min-width: 0;
  margin-left: 0;
  margin-right: 0;
  margin: 0;
  --td-button-height: 96rpx;
  --td-button-font-size: 34rpx;
}

.t-button.action-btn--edit {
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.t-button.action-btn--delete {
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.card-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 16rpx;
}

.card-head__left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-head__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #eef3ff);
}

.card-head__meta {
  flex: none;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: #8d96a3;
}

.card-title {
  min-width: 0;
  font-size: 38rpx;
  font-weight: 800;
  color: #182234;
}

.card-divider {
  height: 1px;
  margin: 18rpx 0 16rpx;
  background: #edf1f5;
}

.card-text {
  font-size: 28rpx;
  color: #7a808d;
  line-height: 1.7;
}

.card--error {
  color: #8c2f2f;
}

.card-button {
  margin-top: 18rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.step-panel {
  border-radius: 24rpx;
  background: #f7f9fd;
  padding: 22rpx;
}

.step-panel + .step-panel {
  margin-top: 16rpx;
}

.step-panel__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--brand);
}

.step-panel__content {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #27323f;
  overflow-wrap: anywhere;
  word-break: break-word;
  word-wrap: break-word;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.gallery-item {
  position: relative;
  overflow: hidden;
  border-radius: 22rpx;
  background: #f2f4f8;
}

.gallery-item--cover {
  border: 4rpx solid var(--brand);
}

.gallery-image {
  width: 100%;
  height: 250rpx;
  display: block;
}

.gallery-badge {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: var(--brand);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.ingredient-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.ingredient-row__num {
  width: 42rpx;
  height: 42rpx;
  flex: none;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--brand);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
}

.ingredient-row__name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #27323f;
}

.ingredient-row__amount {
  flex: none;
  font-size: 24rpx;
  color: #7a808d;
  font-weight: 600;
}

.bottom-actions {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(env(safe-area-inset-bottom) + 14rpx);
}

.footer-close-btn {
  --td-button-default-bg-color: #edf1f6;
  --td-button-default-color: #27323f;
  --td-button-default-border-color: transparent;
  --td-button-height: 88rpx;
  --td-button-font-size: 34rpx;
}
