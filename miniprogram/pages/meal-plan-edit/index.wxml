<view class="meal-plan-edit-page">
  <view class="error-text" wx:if="{{loadErrorMessage}}">{{loadErrorMessage}}</view>

  <view class="form-card">
    <view class="field">
      <view class="field-label">日期</view>
      <picker mode="date" value="{{form.planDate}}" bindchange="handleDateChange">
        <view class="picker-value">{{form.planDate}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">餐次</view>
      <picker
        mode="selector"
        value="{{selectedMealTypeIndex}}"
        range="{{mealTypeOptions}}"
        range-key="label"
        bindchange="handleMealTypeChange"
      >
        <view class="picker-value">{{mealTypeOptions[selectedMealTypeIndex].label}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">计划菜谱</view>
      <view wx:for="{{form.recipes}}" wx:key="index" class="recipe-row">
        <picker
          mode="selector"
          data-index="{{index}}"
          value="{{selectedRecipeIndexes[index]}}"
          range="{{recipeOptions}}"
          range-key="label"
          bindchange="handleRecipeChange"
        >
          <view class="picker-value">{{recipeOptions[selectedRecipeIndexes[index]].label}}</view>
        </picker>

        <input
          class="field-input recipe-row__input"
          value="{{item.servingsOverride}}"
          placeholder="份数（可覆盖）"
          data-index="{{index}}"
          data-field="servingsOverride"
          bindinput="handleRecipeFieldInput"
        />

        <t-button class="recipe-row__remove" theme="danger" variant="outline" size="small" data-index="{{index}}" bindtap="removeRecipeRow">删除这道菜</t-button>
      </view>
      <t-button class="recipe-row__add" theme="primary" variant="outline" size="small" bindtap="addRecipeRow">添加计划菜谱</t-button>
    </view>

    <view class="field">
      <view class="field-label">备注</view>
      <textarea
        class="field-textarea"
        value="{{form.notes}}"
        placeholder="例如：少辣、需要备菜"
        data-field="notes"
        bindinput="handleInput"
      />
    </view>
  </view>

  <view class="action-row">
    <t-button class="ghost-btn" theme="default" variant="outline" bindtap="goBack">取消</t-button>
    <t-button class="primary-btn" theme="primary" loading="{{submitting}}" bindtap="submit">
      {{isEdit ? '保存变更' : '创建计划'}}
    </t-button>
  </view>

  <t-button
    wx:if="{{isEdit}}"
    class="danger-btn"
    theme="danger"
    variant="outline"
    block
    loading="{{deleting}}"
    bindtap="removeMealPlan"
  >
    删除计划
  </t-button>
</view>
