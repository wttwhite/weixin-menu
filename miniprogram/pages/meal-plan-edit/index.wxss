.meal-plan-edit-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(env(safe-area-inset-bottom) + 180rpx);
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, var(--surface-muted, #efe3cf), transparent 28%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, transparent 22%),
    linear-gradient(180deg, var(--page-bg, #f5f1e8) 0%, var(--surface-muted, #efe3cf) 100%);
}

.meal-plan-editor,
.state-card {
  display: grid;
  gap: 22rpx;
}

.editor-section,
.state-card {
  border-radius: 34rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--shadow-soft, 0 20rpx 34rpx rgba(56, 63, 79, 0.1));
}

.state-title {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.state-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary, #7a808d);
}

.state-button {
  margin-top: 20rpx;
  width: fit-content;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.editor-section__head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.editor-section__icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f3f4f7);
  color: var(--brand);
  font-size: 26rpx;
}

.editor-section__icon--danger {
  background: rgba(209, 75, 75, 0.12);
  color: #d14b4b;
}

.editor-section__title {
  min-width: 0;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.editor-section__divider {
  height: 1px;
  margin: 18rpx 0 8rpx;
  background: var(--border-soft, #edf1f5);
}

.section-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-tertiary, #8d96a3);
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.field-card {
  min-width: 0;
}

.field-label {
  margin-top: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary, #70594a);
}

.field-label--compact {
  margin-top: 16rpx;
}

.picker-value,
.field-input,
.field-textarea,
.recipe-selector__search-input,
.recipe-search {
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-soft, #edf1f5);
  background: #fff;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  color: var(--text-primary, #2f241c);
}

.picker-value,
.recipe-search {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
}

.field-input,
.recipe-selector__search-input {
  min-height: 88rpx;
}

.field-input--compact {
  margin-top: 10rpx;
}

.field-textarea {
  margin-top: 16rpx;
  min-height: 160rpx;
  line-height: 1.6;
}

.recipe-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  border: 1rpx solid var(--border-soft, #edf1f5);
}

.recipe-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.recipe-card__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.recipe-search {
  margin-top: 10rpx;
}

.recipe-search--placeholder .recipe-search__text {
  color: #b6bdc8;
}

.recipe-search__text {
  flex: 1;
  min-width: 0;
}

.recipe-search__icon {
  flex: none;
  color: #8c94a2;
  font-size: 30rpx;
  line-height: 1;
}

.row-pill {
  padding: 0 18rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.row-pill--danger {
  background: #ffe9e9;
  color: #d14b4b;
}

.section-button-wrap {
  display: flex;
  justify-content: center;
}

.section-button--soft {
  margin-top: 18rpx;
  width: auto;
  align-self: center;
  --td-button-default-bg-color: var(--surface-muted, #f3f4f7);
  --td-button-default-color: var(--brand);
  --td-button-default-border-color: transparent;
  --td-button-height: 60rpx;
  --td-button-font-size: 22rpx;
}

.editor-section--danger {
  border: 1px solid rgba(209, 75, 75, 0.12);
}

.delete-button {
  margin-top: 24rpx;
  width: auto;
  align-self: flex-start;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 14rpx);
  display: flex;
  gap: 14rpx;
}

.footer-close-btn {
  width: 170rpx;
  --td-button-default-bg-color: #edf1f6;
  --td-button-default-color: var(--text-primary, #27323f);
  --td-button-default-border-color: transparent;
  --td-button-height: 88rpx;
  --td-button-font-size: 32rpx;
}

.footer-submit-btn {
  flex: 1;
  --td-button-primary-bg-color: var(--surface-muted, #f3f4f7);
  --td-button-primary-active-bg-color: var(--surface-muted, #e8edf4);
  --td-button-primary-border-color: transparent;
  --td-button-primary-color: var(--brand);
  --td-button-height: 88rpx;
  --td-button-font-size: 32rpx;
}

.recipe-selector__overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(15, 23, 42, 0.22);
}

.recipe-selector {
  width: 100%;
  max-width: 640rpx;
  border-radius: 28rpx;
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 42rpx rgba(37, 49, 71, 0.18);
}

.recipe-selector__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.recipe-selector__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary, #182234);
}

.recipe-selector__close {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f2f4f8);
  color: var(--text-secondary, #667084);
  font-size: 26rpx;
  font-weight: 700;
}

.recipe-selector__search-input {
  margin-top: 18rpx;
}

.recipe-selector__list {
  margin-top: 18rpx;
  max-height: 52vh;
}

.recipe-selector__list-inner {
  display: grid;
  gap: 12rpx;
}

.recipe-selector__option {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: var(--text-primary, #27323f);
  font-size: 30rpx;
  font-weight: 700;
}

.recipe-selector__empty {
  padding: 28rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary, #8d96a3);
}
