.meal-plan-edit-page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(env(safe-area-inset-bottom) + 40rpx);
  background: var(--page-bg, #f5f1e8);
  box-sizing: border-box;
}

.error-text {
  margin-bottom: 16rpx;
  color: #b44343;
  font-size: 26rpx;
}

.form-card {
  border-radius: 30rpx;
  padding: 28rpx;
  background: var(--surface-bg, #fffaf0);
  box-shadow: 0 4rpx 24rpx rgba(47, 36, 28, 0.07);
}

.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary, #70594a);
}

.picker-value,
.field-input,
.field-textarea {
  width: 100%;
  border-radius: 18rpx;
  border: 1rpx solid rgba(197, 106, 61, 0.18);
  background: #fff;
  padding: 18rpx 22rpx;
  font-size: 28rpx;
  color: var(--text-primary, #2f241c);
  box-sizing: border-box;
}

.field-textarea {
  min-height: 140rpx;
}

.recipe-row {
  margin-top: 14rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(197, 106, 61, 0.04);
  border: 1rpx solid rgba(197, 106, 61, 0.12);
}

.recipe-row__input {
  margin-top: 12rpx;
}

.recipe-row__remove {
  margin-top: 12rpx;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.recipe-row__add {
  margin-top: 12rpx;
  --td-button-outline-primary-color: var(--brand, #c56a3d);
  --td-button-outline-primary-border-color: var(--brand, #c56a3d);
  --td-button-outline-primary-active-bg-color: rgba(197, 106, 61, 0.08);
}

.action-row {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.ghost-btn {
  flex: 1;
  --td-button-default-bg-color: var(--surface-bg, #fffaf0);
  --td-button-default-color: var(--text-primary, #2f241c);
  --td-button-default-border-color: rgba(197, 106, 61, 0.3);
}

.primary-btn {
  flex: 1;
  --td-button-primary-bg-color: var(--brand, #c56a3d);
  --td-button-primary-active-bg-color: var(--brand-strong, #a34e24);
  --td-button-primary-border-color: var(--brand, #c56a3d);
}

.danger-btn {
  margin-top: 20rpx;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}
