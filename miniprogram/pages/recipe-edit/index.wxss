.edit-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.form-card,
.state-card {
  border-radius: 30rpx;
  padding: 32rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.form-title,
.state-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-text,
.state-text {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.state-button {
  margin-top: 22rpx;
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
}

.field-label {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fff;
  font-size: 27rpx;
}

.field-textarea {
  min-height: 148rpx;
}

.field-row {
  display: flex;
  gap: 14rpx;
}

.field-col {
  flex: 1;
}

.field-switch {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.section-title {
  margin-top: 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tag-list {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.inline-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.inline-row__input {
  flex: 1;
  margin-top: 0;
}

.inline-row__button {
  width: 176rpx;
  margin-top: 0;
  background: #fff;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.row-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #fffaf5;
}

.row-card__remove {
  margin-top: 14rpx;
  background: #f6e1e1;
  color: #9d3e3e;
  font-size: 24rpx;
}

.section-button {
  margin-top: 14rpx;
  background: #fff;
  color: var(--text-secondary);
  font-size: 25rpx;
}

.submit-button {
  margin-top: 34rpx;
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
}

.delete-button {
  margin-top: 16rpx;
  background: #f4d8d8;
  color: #8c2f2f;
  font-size: 28rpx;
}
