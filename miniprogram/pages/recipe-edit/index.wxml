<view class="edit-page">
  <view wx:if="{{!activeSpaceId}}" class="state-card">
    <view class="state-title">还没有可用空间</view>
    <view class="state-text">请先切换或创建空间，再管理菜谱。</view>
  </view>

  <view wx:elif="{{loading}}" class="state-card">
    <view class="state-title">正在加载菜谱信息...</view>
  </view>

  <view wx:elif="{{loadErrorMessage}}" class="state-card">
    <view class="state-title">菜谱加载失败</view>
    <view class="state-text">{{loadErrorMessage}}</view>
    <button class="state-button" bindtap="goBack">返回列表</button>
  </view>

  <view wx:else class="form-card">
    <view class="form-title">{{isEdit ? '更新菜谱' : '新建菜谱'}}</view>
    <view class="form-text">维护核心文本、配料步骤和标签，便于共享检索。</view>

    <view class="field-label">名称</view>
    <input class="field-input" data-field="name" value="{{form.name}}" placeholder="例如：麻婆豆腐" bindinput="handleInput" />

    <view class="field-label">摘要</view>
    <textarea class="field-textarea" data-field="summary" value="{{form.summary}}" placeholder="一句话描述这道菜" bindinput="handleInput" />

    <view class="field-row">
      <view class="field-col">
        <view class="field-label">分类</view>
        <input class="field-input" data-field="category" value="{{form.category}}" placeholder="热菜/汤/甜品" bindinput="handleInput" />
      </view>
      <view class="field-col">
        <view class="field-label">菜系</view>
        <input class="field-input" data-field="cuisine" value="{{form.cuisine}}" placeholder="川菜/粤菜" bindinput="handleInput" />
      </view>
    </view>

    <view class="field-row">
      <view class="field-col">
        <view class="field-label">难度</view>
        <input class="field-input" data-field="difficulty" value="{{form.difficulty}}" placeholder="简单/中等/困难" bindinput="handleInput" />
      </view>
      <view class="field-col">
        <view class="field-label">推荐分</view>
        <input class="field-input" data-field="recommendationScore" value="{{form.recommendationScore}}" placeholder="0-100" type="number" bindinput="handleInput" />
      </view>
    </view>

    <view class="field-row">
      <view class="field-col">
        <view class="field-label">份量</view>
        <input class="field-input" data-field="servings" value="{{form.servings}}" placeholder="2-3 人" bindinput="handleInput" />
      </view>
    </view>

    <view class="field-row">
      <view class="field-col">
        <view class="field-label">备菜时长(分钟)</view>
        <input class="field-input" data-field="prepTimeMinutes" value="{{form.prepTimeMinutes}}" bindinput="handleInput" />
      </view>
      <view class="field-col">
        <view class="field-label">烹饪时长(分钟)</view>
        <input class="field-input" data-field="cookTimeMinutes" value="{{form.cookTimeMinutes}}" bindinput="handleInput" />
      </view>
    </view>

    <view class="field-switch">
      <text>收藏这道菜</text>
      <switch checked="{{form.isFavorite}}" bindchange="handleSwitchFavorite" />
    </view>

    <view class="section-title">标签</view>
    <view class="tag-list">
      <tag-chip
        wx:for="{{tagViewItems}}"
        wx:key="_id"
        tagId="{{item._id}}"
        text="{{item.name}}"
        color="{{item.color}}"
        selected="{{item.selected}}"
        removable="{{true}}"
        bindselect="handleTagToggle"
        bindremove="deleteTag"
      />
    </view>
    <view class="inline-row">
      <input class="field-input inline-row__input" value="{{newTagName}}" placeholder="添加新标签名称" bindinput="handleNewTagInput" />
      <button class="inline-row__button" bindtap="createTag">添加标签</button>
    </view>

    <view class="section-title">配料</view>
    <view wx:for="{{form.ingredients}}" wx:key="index" class="row-card">
      <view class="field-label">配料 {{index + 1}}</view>
      <input class="field-input" data-index="{{index}}" data-field="name" value="{{item.name}}" placeholder="名称" bindinput="handleIngredientInput" />
      <view class="field-row">
        <input class="field-input field-col" data-index="{{index}}" data-field="quantity" value="{{item.quantity}}" placeholder="数量" bindinput="handleIngredientInput" />
        <input class="field-input field-col" data-index="{{index}}" data-field="unit" value="{{item.unit}}" placeholder="单位" bindinput="handleIngredientInput" />
      </view>
      <input class="field-input" data-index="{{index}}" data-field="preparation" value="{{item.preparation}}" placeholder="处理方式（可选）" bindinput="handleIngredientInput" />
      <input class="field-input" data-index="{{index}}" data-field="notes" value="{{item.notes}}" placeholder="备注（可选）" bindinput="handleIngredientInput" />
      <button class="row-card__remove" data-index="{{index}}" bindtap="removeIngredientRow">删除该配料</button>
    </view>
    <button class="section-button" bindtap="addIngredientRow">添加配料行</button>

    <view class="section-title">步骤</view>
    <view wx:for="{{form.steps}}" wx:key="index" class="row-card">
      <view class="field-label">步骤 {{index + 1}}</view>
      <input class="field-input" data-index="{{index}}" data-field="title" value="{{item.title}}" placeholder="标题（可选）" bindinput="handleStepInput" />
      <textarea class="field-textarea" data-index="{{index}}" data-field="content" value="{{item.content}}" placeholder="步骤内容" bindinput="handleStepInput" />
      <input class="field-input" data-index="{{index}}" data-field="durationMinutes" value="{{item.durationMinutes}}" placeholder="时长（分钟，可选）" bindinput="handleStepInput" />
      <input class="field-input" data-index="{{index}}" data-field="tips" value="{{item.tips}}" placeholder="提示（可选）" bindinput="handleStepInput" />
      <button class="row-card__remove" data-index="{{index}}" bindtap="removeStepRow">删除该步骤</button>
    </view>
    <button class="section-button" bindtap="addStepRow">添加步骤行</button>

    <view class="section-title">备注与来源</view>
    <textarea class="field-textarea" data-field="notes" value="{{form.notes}}" placeholder="备注（可选）" bindinput="handleInput" />
    <input class="field-input" data-field="sourceName" value="{{form.sourceName}}" placeholder="来源名称（可选）" bindinput="handleInput" />
    <input class="field-input" data-field="sourceUrl" value="{{form.sourceUrl}}" placeholder="来源链接（可选）" bindinput="handleInput" />

    <button class="submit-button" loading="{{submitting}}" bindtap="submit">{{isEdit ? '保存修改' : '创建菜谱'}}</button>
    <button wx:if="{{isEdit}}" class="delete-button" loading="{{deleting}}" bindtap="removeRecipe">删除菜谱</button>
  </view>
</view>
