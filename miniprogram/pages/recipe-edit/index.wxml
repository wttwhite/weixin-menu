<view class="edit-page" style="{{themeStyle}}">
  <view wx:if="{{!activeSpaceId}}" class="state-card">
    <view class="state-title">还没有可用空间</view>
    <view class="state-text">请先切换或创建空间，再管理菜谱。</view>
  </view>

  <view wx:elif="{{loading}}" class="state-card">
    <view class="state-title">{{loadingTitle}}</view>
  </view>

  <view wx:elif="{{isEdit && loadErrorMessage}}" class="state-card">
    <view class="state-title">菜谱加载失败</view>
    <view class="state-text">{{loadErrorMessage}}</view>
    <button class="state-button" bindtap="goBack">返回列表</button>
  </view>

  <view wx:else class="editor-shell">
    <view class="editor-section">
      <view class="editor-section__head">
        <view class="editor-section__icon">ⓘ</view>
        <view class="editor-section__title">基本信息</view>
      </view>
      <view class="editor-section__divider"></view>

      <view class="form-row">
        <view class="form-row__label"><text class="form-row__required">*</text>菜谱名称</view>
        <input
          class="field-input field-input--inline"
          data-field="name"
          value="{{form.name}}"
          placeholder="请输入菜谱名称"
          bindinput="handleInput"
        />
      </view>

      <view class="form-row">
        <view class="form-row__label"><text class="form-row__required">*</text>菜谱分类</view>
        <view class="category-picker" bindtap="openCategorySelector">
          <view class="{{categoryPickerClass}}">
            <text>{{selectedCategoryLabel}}</text>
            <view class="category-picker__arrow"></view>
          </view>
        </view>
      </view>

      <view class="form-row form-row--textarea description-row">
        <view class="form-row__label">菜谱描述</view>
        <view class="description-row__main">
          <view class="description-row__field-wrap">
            <textarea
              class="field-textarea field-textarea--hero field-textarea--inline"
              data-field="summary"
              value="{{form.summary}}"
              maxlength="100"
              placeholder="简单描述一下这道菜的特色..."
              placeholder-class="field-placeholder"
              bindinput="handleInput"
            />
          </view>
          <view class="description-row__count">{{summaryCount}}/100</view>
        </view>
      </view>
    </view>

    <view class="editor-section">
      <view class="editor-section__head">
        <view class="editor-section__icon">🛒</view>
        <view class="editor-section__title">食材与步骤</view>
      </view>
      <view class="editor-section__divider"></view>

      <view class="subsection-title">食材列表</view>
      <view wx:for="{{ingredientViewItems}}" wx:key="displayIndex" class="row-card row-card--ingredient">
        <input
          class="field-input field-input--plain"
          data-index="{{index}}"
          data-field="name"
          value="{{item.name}}"
          placeholder="如：土豆 2个、五花肉 500g"
          placeholder-class="field-placeholder"
          bindinput="handleIngredientInput"
        />
        <view class="row-card__side-actions">
          <view class="row-card__pill row-card__pill--danger" data-index="{{index}}" bindtap="removeIngredientRow">删除</view>
        </view>
      </view>
      <view class="section-button-wrap">
        <t-button class="section-button section-button--soft" bindtap="addIngredientRow">＋ 新增食材</t-button>
      </view>

      <view class="subsection-title subsection-title--steps">制作步骤</view>
      <view wx:for="{{stepViewItems}}" wx:key="displayIndex" class="step-card">
        <view class="step-card__head">
          <view>
            <view class="step-card__title">步骤 {{item.displayIndex}}</view>
            <view class="step-card__count">{{item.contentCount}}/500</view>
          </view>
          <view class="row-card__pill row-card__pill--danger" data-index="{{index}}" bindtap="removeStepRow">删除</view>
        </view>
        <textarea
          class="field-textarea field-textarea--step"
          data-index="{{index}}"
          data-field="content"
          value="{{item.content}}"
          maxlength="500"
          placeholder="详细描述制作步骤..."
          placeholder-class="field-placeholder"
          bindinput="handleStepInput"
        />
      </view>
      <view class="section-button-wrap">
        <t-button class="section-button section-button--soft" bindtap="addStepRow">＋ 新增步骤</t-button>
      </view>
    </view>

    <view class="editor-section editor-section--last">
      <view class="editor-section__head">
        <view class="editor-section__icon">⚙</view>
        <view class="editor-section__title">详细属性</view>
      </view>
      <view class="editor-section__divider"></view>

      <view class="subsection-title">烹饪时长</view>
      <view class="duration-chip-list">
        <view
          wx:for="{{cookDurationOptions}}"
          wx:key="value"
          class="{{item.itemClass}}"
          data-value="{{item.value}}"
          bindtap="handleCookTimeOptionTap"
        >
          {{item.label}}
        </view>
      </view>

      <view class="rating-row">
        <view class="rating-row__label">推荐指数</view>
        <view class="rating-row__stars">
          <text wx:for="{{recommendationStarItems}}" wx:key="value" class="{{item.itemClass}}" data-value="{{item.value}}" bindtap="handleRecommendationTap">★</text>
        </view>
        <view class="rating-row__value">{{recommendationScoreLabel}}</view>
      </view>

      <input class="field-input field-input--hidden" data-field="recommendationScore" value="{{form.recommendationScore}}" bindinput="handleInput" />

      <view class="subsection-title">菜谱图片上传</view>
      <view class="subsection-hint">多张可选封面图</view>
      <image-uploader
        label=""
        items="{{form.images}}"
        coverImageId="{{form.coverImageId}}"
        spaceId="{{activeSpaceId}}"
        recipeId="{{recipeId}}"
        imageRole="cover"
        bindpendingadd="handleImagePendingAdd"
        binduploaded="handleImageUploaded"
        binduploaderror="handleImageUploadError"
        bindcover="handleImageCoverSelect"
        bindremove="handleImageRemove"
      />

      <view class="detail-grid">
        <view class="detail-grid__item">
          <view class="field-label">菜系</view>
          <input class="field-input" data-field="cuisine" value="{{form.cuisine}}" placeholder="例如：川菜" bindinput="handleInput" />
        </view>
        <view class="detail-grid__item">
          <view class="field-label">难度</view>
          <input class="field-input" data-field="difficulty" value="{{form.difficulty}}" placeholder="简单 / 中等" bindinput="handleInput" />
        </view>
      </view>

      <view class="field-switch">
        <text>收藏这道菜</text>
        <switch checked="{{form.isFavorite}}" bindchange="handleSwitchFavorite" />
      </view>
    </view>

    <view wx:if="{{isEdit}}" class="editor-section editor-section--danger">
      <view class="editor-section__head">
        <view class="editor-section__icon editor-section__icon--danger">!</view>
        <view class="editor-section__title">危险操作</view>
      </view>
      <view class="editor-section__divider"></view>
      <t-button class="delete-button" theme="danger" variant="outline" loading="{{deleting}}" bindtap="removeRecipe">删除菜谱</t-button>
    </view>

    <view class="bottom-actions">
      <t-button class="footer-close-btn footer-close-button" theme="default" bindtap="goBack">关闭</t-button>
      <t-button class="footer-submit-btn footer-submit-button" theme="primary" loading="{{submitting}}" bindtap="submit">{{submitButtonLabel}}</t-button>
    </view>
  </view>

  <view wx:if="{{showCategorySelector}}" class="category-selector__overlay" catchtap="closeCategorySelector" catchtouchmove="noop">
    <view class="category-selector" catchtap="noop" catchtouchmove="noop">
      <view class="category-selector__header">
        <view class="category-selector__title">选择菜谱分类</view>
        <view class="category-selector__close" bindtap="closeCategorySelector">×</view>
      </view>
      <scroll-view scroll-y="true" class="category-selector__list">
        <view class="category-selector__list-inner">
          <view
            wx:for="{{categorySelectorItems}}"
            wx:key="label"
            class="{{item.itemClass}}"
            data-name="{{item.label}}"
            bindtap="handleCategoryOptionTap"
          >
            {{item.label}}
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
