.statistics-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 28rpx 24rpx calc(env(safe-area-inset-bottom) + 140rpx);
  box-sizing: border-box;
}

.statistics-hero {
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  padding: 30rpx 28rpx 28rpx;
  background:
    radial-gradient(circle at 86% 18%, var(--hero-soft-glow, rgba(255, 255, 255, 0.46)), transparent 18%),
    radial-gradient(circle at 16% 12%, var(--hero-soft-glow-weak, rgba(255, 255, 255, 0.22)), transparent 20%),
    linear-gradient(145deg, var(--hero-soft-start, #edf5f7) 0%, var(--hero-soft-end, #d9eaee) 100%);
  color: var(--hero-soft-text, #24414a);
  box-shadow: var(--shadow-soft, 0 18rpx 40rpx rgba(63, 50, 38, 0.08));
}

.statistics-hero::before {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 180rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
  opacity: 0.68;
  transform: rotate(-8deg);
}

.statistics-hero::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 44rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, var(--hero-soft-glow-weak, rgba(255, 255, 255, 0.22)), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.statistics-hero__kicker {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--hero-soft-subtle, #6e8790);
}

.statistics-hero__title {
  margin-top: 14rpx;
  font-size: 50rpx;
  line-height: 1.08;
  font-weight: 800;
  color: var(--hero-soft-text, #24414a);
}

.statistics-hero__summary {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-secondary, #5c6872);
}

.statistics-hero__chips {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.statistics-hero__chip {
  padding: 18rpx 16rpx;
  border-radius: 24rpx;
  background: var(--hero-soft-panel-bg, rgba(255, 255, 255, 0.55));
  box-shadow: inset 0 0 0 1px var(--hero-soft-chip-border, rgba(255, 255, 255, 0.34));
}

.statistics-hero__chip-label {
  font-size: 22rpx;
  color: var(--hero-soft-subtle, #6e8790);
}

.statistics-hero__chip-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--hero-soft-text, #24414a);
}

.feedback-card {
  margin-top: 20rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: var(--surface-bg, rgba(255, 255, 255, 0.96));
  box-shadow: var(--shadow-soft, 0 18rpx 40rpx rgba(63, 50, 38, 0.08));
  color: var(--text-secondary, #5c6872);
  font-size: 26rpx;
}

.feedback-card--error {
  color: var(--danger, #b64a3a);
}

.statistics-body {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.statistics-section-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.statistics-section-head__eyebrow {
  font-size: 22rpx;
  color: var(--text-tertiary, #89949d);
}

.statistics-section-head__title {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--text-primary, #202a33);
}

.statistics-metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.statistics-metric-card,
.statistics-progress-card,
.statistics-insight-card,
.statistics-action-row {
  border-radius: 34rpx;
  background: var(--surface-bg, rgba(255, 255, 255, 0.96));
  box-shadow: var(--shadow-soft, 0 18rpx 40rpx rgba(63, 50, 38, 0.08));
}

.statistics-metric-card {
  padding: 22rpx;
}

.statistics-metric-card__label {
  font-size: 22rpx;
  color: var(--text-tertiary, #89949d);
}

.statistics-metric-card__value {
  margin-top: 12rpx;
  font-size: 46rpx;
  line-height: 1;
  font-weight: 800;
  color: var(--text-primary, #202a33);
}

.statistics-metric-card__desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-secondary, #5c6872);
}

.statistics-progress-card {
  padding: 24rpx;
}

.statistics-progress-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.statistics-progress-card__label {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary, #202a33);
}

.statistics-progress-card__meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #5c6872);
}

.statistics-progress-card__percent {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--brand, #4f7d8a);
}

.statistics-progress-card__track {
  height: 16rpx;
  margin-top: 20rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: var(--surface-muted, #e8edf1);
}

.statistics-progress-card__fill {
  height: 100%;
  min-width: 24rpx;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--brand, #4f7d8a), var(--brand-strong, #365e69));
}

.statistics-insight-list,
.statistics-action-list {
  display: grid;
  gap: 14rpx;
}

.statistics-insight-card {
  padding: 22rpx 24rpx;
}

.statistics-insight-card__label {
  font-size: 22rpx;
  color: var(--text-tertiary, #89949d);
}

.statistics-insight-card__value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary, #202a33);
}

.statistics-insight-card__desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary, #5c6872);
}

.statistics-action-row {
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.statistics-action-row__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #e8edf1);
  font-size: 30rpx;
}

.statistics-action-row__body {
  flex: 1;
  min-width: 0;
}

.statistics-action-row__title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary, #202a33);
}

.statistics-action-row__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-secondary, #5c6872);
}

.statistics-action-row__arrow {
  flex: none;
  font-size: 28rpx;
  color: var(--text-tertiary, #89949d);
}
