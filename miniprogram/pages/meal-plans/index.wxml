<view class="meal-plans-page" style="{{themeStyle}}">
  <view class="plans-hero">
    <image class="plans-hero__background" src="/images/meal-plans-hero.jpg" mode="aspectFill" />
    <view class="plans-hero__overlay">
      <view class="plans-hero__topbar">
        <view class="plans-hero__date-pill">{{currentDateLabel}}</view>
        <view class="plans-hero__stat-pill">
          <view class="plans-hero__stat-value">{{monthPlanCount}}</view>
          <view class="plans-hero__stat-label">个计划</view>
        </view>
      </view>
      <view class="plans-hero__title">做饭计划</view>
      <view class="plans-hero__subtitle">本周菜谱安排，合理规划每日饮食</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>
  <view wx:if="{{!errorMessage && truncationMessage}}" class="feedback-card">{{truncationMessage}}</view>

  <view wx:if="{{!activeSpaceId}}" class="empty-card">
    <view class="empty-card__title">先选择一个空间</view>
    <view class="empty-card__text">空间用于团队共享菜谱、库存、计划和采购数据。</view>
    <t-button class="empty-card__button" theme="primary" block bindtap="openSpace">前往选择空间</t-button>
  </view>

  <view wx:elif="{{loading}}" class="feedback-card">正在读取计划...</view>

  <view wx:else>
    <view class="calendar-panel">
      <view class="calendar-panel__nav">
        <view class="calendar-nav__button" bindtap="goPrevMonth">‹</view>
        <view class="calendar-nav__month">{{viewMonthLabel}}</view>
        <view class="calendar-nav__button" bindtap="goNextMonth">›</view>
        <t-button t-class="calendar-nav__today" theme="primary" size="small" shape="round" bindtap="goToday">回到今日</t-button>
      </view>

      <view class="calendar-weekdays">
        <view wx:for="{{weekDayLabels}}" wx:key="index" class="calendar-weekdays__item">{{item}}</view>
      </view>

      <view class="calendar-panel__viewport" style="{{calendarViewportStyle}}">
        <view class="calendar-grid" style="{{calendarGridStyle}}">
          <view
            wx:for="{{calendarItems}}"
            wx:key="key"
            class="{{item.itemClass}}"
            data-date="{{item.date}}"
            bindtap="handleCalendarDateSelect"
          >
            <view wx:if="{{!item.isBlank}}" class="calendar-cell__day">{{item.label}}</view>
            <view wx:if="{{item.showDot}}" class="{{item.dotClass}}"></view>
          </view>
        </view>
      </view>

      <view class="calendar-toggle" bindtap="toggleCalendarExpanded">
        <view class="calendar-toggle__chevron {{isCalendarExpanded ? 'calendar-toggle__chevron--expanded' : ''}}">⌄</view>
      </view>
    </view>

    <view class="plans-day-card">
      <view class="plans-day-card__head">
        <view>
          <view class="plans-day-card__title">{{selectedDateTitle}}</view>
          <view class="plans-day-card__meta">{{selectedPlanCountText}}</view>
        </view>
        <t-button wx:if="{{selectedPlans.length}}" t-class="plans-day-card__action plans-day-card__action--inventory" theme="primary" size="small" shape="round" bindtap="openInventoryCheck">检查库存</t-button>
        <view wx:else class="plans-day-card__action plans-day-card__action--create" bindtap="goCreate">添加安排</view>
      </view>

      <view wx:if="{{selectedPlans.length}}" class="plan-card-list">
        <view wx:for="{{selectedPlans}}" wx:key="_id" class="plan-card" data-meal-plan-id="{{item._id}}" bindtap="handleSelectMealPlan">
          <view class="plan-card__icon">{{item.utensilText}}</view>
          <view class="plan-card__body">
            <view class="plan-card__head">
              <view class="plan-card__title-wrap">
                <view class="plan-card__title">{{item.mealTypeLabel}}</view>
                <view class="{{item.statusClass}}">{{item.statusText}}</view>
              </view>
              <view class="plan-card__tools">
                <view
                  class="{{item.statusToolClass}}"
                  data-meal-plan-id="{{item._id}}"
                  catchtap="handleToggleMealPlanStatus"
                >
                  {{item.statusIconText}}
                </view>
                <view
                  class="plan-card__tool plan-card__tool--edit"
                  data-meal-plan-id="{{item._id}}"
                  catchtap="handleSelectMealPlan"
                >
                  ✎
                </view>
              </view>
            </view>
            <view class="plan-card__meta">{{item.planCountText}}</view>
            <view class="plan-card__tags">
              <view
                wx:for="{{item.recipeTagItems}}"
                wx:key="recipeId"
                class="plan-card__recipe-tag"
                data-recipe-id="{{item.recipeId}}"
                catchtap="handlePlanRecipeTap"
              >
                {{item.label}}
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-card empty-card--inline">
        <view class="empty-card__title">当天还没有安排</view>
        <view class="empty-card__text">{{emptyMessage}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showMealPlanStatusModal}}" class="meal-plan-status-modal__overlay" catchtap="closeMealPlanStatusModal">
    <view class="meal-plan-status-modal" catchtap="noop">
      <view class="meal-plan-status-modal__header">
        <view>
          <view class="meal-plan-status-modal__title">{{mealPlanStatusModalTitle}}</view>
          <view class="meal-plan-status-modal__date">{{mealPlanStatusModalDate}}</view>
        </view>
        <view class="meal-plan-status-modal__close" bindtap="closeMealPlanStatusModal">×</view>
      </view>

      <view class="meal-plan-status-modal__section">
        <view class="meal-plan-status-modal__label">状态</view>
        <view class="meal-plan-status-modal__chips">
          <view
            wx:for="{{mealPlanStatusChipItems}}"
            wx:key="value"
            class="{{item.itemClass}}"
            data-status="{{item.value}}"
            catchtap="selectMealPlanStatus"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="meal-plan-status-modal__row">
        <view class="meal-plan-status-modal__label">餐次</view>
        <view class="meal-plan-status-modal__value">{{mealPlanStatusModalMealTypeLabel}}</view>
      </view>

      <view class="meal-plan-status-modal__section">
        <view class="meal-plan-status-modal__label">{{mealPlanStatusModalRecipeCountText}}</view>
        <view class="meal-plan-status-modal__recipe-list">
          <view
            wx:for="{{mealPlanStatusModalRecipeItems}}"
            wx:key="recipeId"
            class="{{item.itemClass}}"
            data-recipe-id="{{item.recipeId}}"
            bindtap="handlePlanRecipeTap"
          >
            <view class="meal-plan-status-modal__recipe-icon">⌕</view>
            <view class="meal-plan-status-modal__recipe-name">{{item.label}}</view>
          </view>
        </view>
      </view>

      <view class="meal-plan-status-modal__footer">
        <view class="meal-plan-status-modal__delete" bindtap="removeSelectedMealPlan">🗑 删除计划</view>
      </view>
    </view>
  </view>

  <view wx:if="{{showInventoryModal}}" class="inventory-modal__overlay" catchtap="closeInventoryModal">
    <view class="inventory-modal" catchtap="closeInventoryModal">
      <view class="inventory-modal__panel" catchtap="noop">
        <view class="inventory-modal__header">
          <view>
            <view class="inventory-modal__title">食材库存检查</view>
            <view class="inventory-modal__date">{{inventoryCheckDateLabel}}</view>
          </view>
          <view class="inventory-modal__close" bindtap="closeInventoryModal">×</view>
        </view>

        <view wx:if="{{inventoryModalLoading}}" class="feedback-card feedback-card--inline">正在检查库存...</view>

        <view wx:else>
          <view class="inventory-modal__summary">
            <view class="inventory-stat">
              <view class="inventory-stat__value">{{inventorySummary.totalText}}</view>
              <view class="inventory-stat__label">需食材</view>
            </view>
            <view class="inventory-stat inventory-stat--ok">
              <view class="inventory-stat__value">{{inventorySummary.inStockText}}</view>
              <view class="inventory-stat__label">库存充足</view>
            </view>
            <view class="inventory-stat inventory-stat--missing">
              <view class="inventory-stat__value">{{inventorySummary.missingText}}</view>
              <view class="inventory-stat__label">需采购</view>
            </view>
          </view>

          <view class="inventory-list">
            <view wx:for="{{inventoryItems}}" wx:key="key" class="inventory-item {{item.selectable ? 'inventory-item--missing' : 'inventory-item--ok'}}">
              <view class="{{item.iconClass}}">{{item.iconText}}</view>
              <view class="inventory-item__body">
                <view class="inventory-item__name">{{item.name}}</view>
                <view class="inventory-item__meta">{{item.requiredText}}</view>
                <view class="inventory-item__meta">{{item.stockText}}</view>
              </view>
              <view
                wx:if="{{item.selectable}}"
                class="inventory-item__checkbox {{item.selected ? 'inventory-item__checkbox--selected' : ''}}"
                data-key="{{item.key}}"
                bindtap="toggleInventorySelection"
              >
                {{item.selected ? '✓' : ''}}
              </view>
              <view class="{{item.statusClass}}">{{item.statusText}}</view>
            </view>
          </view>

          <t-button class="inventory-modal__primary" theme="primary" block bindtap="generateShoppingList">{{inventoryGenerateButtonText}}</t-button>
        </view>
      </view>
    </view>
  </view>
</view>
