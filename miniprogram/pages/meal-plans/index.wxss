page {
  background: transparent;
}

.meal-plans-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 18rpx 18rpx calc(env(safe-area-inset-bottom) + 26rpx);
  box-sizing: border-box;
}

.plans-hero {
  position: relative;
  height: 286rpx;
  overflow: hidden;
  border-radius: 32rpx;
  box-shadow: var(--shadow-soft, 0 24rpx 44rpx rgba(36, 52, 82, 0.14));
}

.plans-hero__background {
  width: 100%;
  height: 100%;
}

.plans-hero__overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 12rpx;
  padding: 24rpx 24rpx 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(19, 29, 42, 0.1), rgba(19, 29, 42, 0.46));
  color: #fff;
}

.plans-hero__topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.plans-hero__date-pill {
  width: fit-content;
  max-width: 100%;
  min-width: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.plans-hero__title {
  margin-top: auto;
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 800;
  text-align: left;
}

.plans-hero__subtitle {
  max-width: 100%;
  font-size: 24rpx;
  line-height: 1.4;
  opacity: 0.92;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: left;
}

.plans-hero__stat-pill {
  width: fit-content;
  max-width: 100%;
  min-width: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: baseline;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
}

.plans-hero__stat-value {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
}

.plans-hero__stat-label {
  font-size: 22rpx;
  white-space: nowrap;
}

.feedback-card,
.empty-card,
.calendar-panel,
.plans-day-card {
  margin-top: 18rpx;
  border-radius: 30rpx;
  padding: 24rpx;
  background: var(--surface-bg, rgba(255, 255, 255, 0.97));
  box-shadow: var(--shadow-soft, 0 18rpx 34rpx rgba(56, 63, 79, 0.1));
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary, #5b6575);
}

.feedback-card--error {
  color: var(--danger, #8c2f2f);
}

.feedback-card--inline {
  margin-top: 14rpx;
  background: var(--surface-muted, #f7f9fc);
  box-shadow: none;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary, #27323f);
}

.empty-card__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary, #7a808d);
}

.empty-card__button {
  margin-top: 18rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.empty-card--inline {
  margin-top: 12rpx;
  box-shadow: none;
}

.calendar-panel__nav {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.calendar-nav__button {
  width: 72rpx;
  min-width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #f2f4f8);
  color: var(--text-primary, #394556);
  font-size: 42rpx;
  font-weight: 500;
  text-align: center;
}

.calendar-nav__month {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #f7f8fb);
  border: 1px solid var(--border-soft, #e4e8ef);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary, #27323f);
  text-align: center;
}

.t-button.calendar-nav__today {
  display: inline-flex;
  flex: none;
  width: auto;
  margin-left: 0;
  margin-right: 0;
  min-width: 0;
  padding-left: 12rpx;
  padding-right: 12rpx;
  white-space: nowrap;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 18rpx;
}

.calendar-weekdays__item {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-tertiary, #8a90a0);
  font-weight: 700;
}

.calendar-panel__viewport {
  margin-top: 16rpx;
  overflow: hidden;
  transition: height 220ms ease;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  transition: transform 220ms ease, opacity 180ms ease;
  will-change: transform;
}

.calendar-cell {
  height: 88rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f7f8fb);
  border: 2rpx solid transparent;
  color: var(--text-primary, #384454);
}

.calendar-cell--blank {
  background: transparent;
}

.calendar-cell--has-plans {
  background: rgba(255, 255, 255, 0.92);
}

.calendar-cell--outside-month {
  background: var(--surface-muted, #f3f4f7);
  color: var(--text-tertiary, #bcc2cd);
}

.calendar-cell--outside-month.calendar-cell--has-plans {
  background: var(--surface-muted, #f3f4f7);
}

.calendar-cell--today {
  background: var(--surface-muted, rgba(86, 163, 108, 0.14));
}

.calendar-cell--selected {
  border-color: var(--brand);
  box-shadow: inset 0 0 0 2rpx var(--border-soft, rgba(197, 106, 61, 0.08));
}

.calendar-cell__day {
  font-size: 28rpx;
  font-weight: 700;
}

.calendar-cell__dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 6rpx;
  border-radius: 999rpx;
  background: var(--text-tertiary, #4c7fe4);
}

.calendar-cell__dot--selected {
  background: var(--brand);
}

.calendar-toggle {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 10rpx;
  padding-top: 4rpx;
}

.calendar-toggle__chevron {
  width: 56rpx;
  height: 40rpx;
  border-radius: 999rpx;
  color: var(--text-secondary, #7d8797);
  font-size: 34rpx;
  line-height: 40rpx;
  text-align: center;
  transition: transform 220ms ease, color 180ms ease;
}

.calendar-toggle__chevron--expanded {
  transform: rotate(180deg);
}

.plans-day-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.plans-day-card__title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.plans-day-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #7a808d);
}

.plans-day-card__action {
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.t-button.plans-day-card__action--inventory {
  display: inline-flex;
  flex: none;
  width: auto;
  min-width: 0;
  margin-left: 0;
  margin-right: 0;
  padding-left: 16rpx;
  padding-right: 16rpx;
  white-space: nowrap;
}

.plans-day-card__action--create {
  flex: none;
  width: auto;
  min-width: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 24rpx rgba(53, 117, 74, 0.18);
  white-space: nowrap;
}

.plan-card-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.plan-card {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 18rpx;
  border-radius: 28rpx;
  border: 1px solid var(--border-soft, rgba(39, 65, 49, 0.1));
  background: rgba(255, 255, 255, 0.92);
}

.plan-card__icon {
  width: 76rpx;
  min-width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f3f4f7);
  font-size: 36rpx;
}

.plan-card__body {
  flex: 1;
  min-width: 0;
}

.plan-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.plan-card__title-wrap {
  flex: 1;
  min-width: 0;
}

.plan-card__title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.plan-card__status {
  margin-top: 8rpx;
  width: fit-content;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.9);
}

.plan-card__status--done {
  color: var(--success, #2f8a54);
}

.plan-card__status--today {
  color: var(--brand);
}

.plan-card__status--upcoming {
  color: var(--text-tertiary, #8a90a0);
}

.plan-card__status--cancelled {
  color: var(--text-tertiary, #8a90a0);
}

.plan-card__tools {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: none;
}

.plan-card__tool {
  width: 58rpx;
  min-width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  background: var(--surface-muted, #f3f4f7);
  color: var(--text-primary, #27323f);
}

.plan-card__tool--edit {
  color: var(--text-secondary, #5e7765);
}

.plan-card__tool--status {
  color: #ffffff;
}

.plan-card__tool--done {
  background: var(--success, #2f8a54);
}

.plan-card__tool--today,
.plan-card__tool--upcoming {
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
}

.plan-card__tool--cancelled {
  background: var(--text-tertiary, #8a90a0);
}

.plan-card__meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary, #7a808d);
}

.plan-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.plan-card__recipe-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1px solid var(--border-soft, rgba(39, 65, 49, 0.12));
  background: rgba(255, 255, 255, 0.96);
  color: var(--brand-strong, #35754a);
  font-size: 22rpx;
  font-weight: 700;
}

.meal-plan-status-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 64;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(18, 28, 45, 0.42);
  backdrop-filter: blur(10rpx);
}

.meal-plan-status-modal {
  width: 100%;
  max-width: 680rpx;
  border-radius: 34rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 28rpx 50rpx rgba(22, 35, 54, 0.22);
}

.meal-plan-status-modal__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.meal-plan-status-modal__title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.meal-plan-status-modal__date {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text-tertiary, #8a90a0);
}

.meal-plan-status-modal__close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f3f4f7);
  color: var(--text-secondary, #7a808d);
  font-size: 36rpx;
}

.meal-plan-status-modal__section {
  margin-top: 24rpx;
}

.meal-plan-status-modal__row {
  margin-top: 20rpx;
  padding: 20rpx 0;
  border-top: 1px solid var(--border-soft, rgba(39, 65, 49, 0.12));
  border-bottom: 1px solid var(--border-soft, rgba(39, 65, 49, 0.12));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meal-plan-status-modal__label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-secondary, #5e7765);
}

.meal-plan-status-modal__value {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary, #27323f);
}

.meal-plan-status-modal__chips {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.meal-plan-status-chip {
  min-width: 132rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #f3f4f7);
  color: var(--text-secondary, #7a808d);
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.meal-plan-status-chip--active {
  border-color: rgba(255, 255, 255, 0.22);
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(53, 117, 74, 0.2);
}

.meal-plan-status-modal__recipe-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.meal-plan-status-modal__recipe-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: var(--surface-muted, #f3f4f7);
}

.meal-plan-status-modal__recipe-item--disabled {
  opacity: 0.5;
}

.meal-plan-status-modal__recipe-icon {
  width: 46rpx;
  min-width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  color: var(--text-primary, #27323f);
  font-size: 24rpx;
  font-weight: 800;
}

.meal-plan-status-modal__recipe-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary, #27323f);
}

.meal-plan-status-modal__footer {
  display: flex;
  justify-content: center;
  margin-top: 30rpx;
}

.meal-plan-status-modal__delete {
  min-width: 240rpx;
  padding: 18rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(255, 110, 110, 0.16);
  color: #d95b5b;
  font-size: 32rpx;
  font-weight: 800;
  text-align: center;
}

.inventory-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(18, 28, 45, 0.36);
  backdrop-filter: blur(8rpx);
}

.inventory-modal__panel {
  width: 100%;
  min-width: 500rpx;
  max-width: 720rpx;
  max-height: 82vh;
  overflow: auto;
  box-sizing: border-box;
  border-radius: 34rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 28rpx 50rpx rgba(22, 35, 54, 0.22);
}

.inventory-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.inventory-modal__title {
  font-size: 44rpx;
  font-weight: 800;
  color: #182234;
}

.inventory-modal__date {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #8a90a0;
}

.inventory-modal__close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f4f8;
  color: #667084;
  font-size: 36rpx;
}

.inventory-modal__summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: #f8fafc;
}

.inventory-stat {
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
}

.inventory-stat--ok {
  background: rgba(86, 163, 108, 0.12);
}

.inventory-stat--missing {
  background: #fdeaea;
}

.inventory-stat__value {
  font-size: 54rpx;
  font-weight: 800;
  color: #27323f;
}

.inventory-stat__label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5f6876;
}

.inventory-list {
  display: grid;
  gap: 14rpx;
  margin-top: 20rpx;
}

.inventory-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  padding: 18rpx;
  border-radius: 26rpx;
  background: #f9fafc;
}

.inventory-item--ok {
  background: linear-gradient(180deg, rgba(226, 248, 232, 0.96), rgba(240, 252, 244, 0.96));
}

.inventory-item--missing {
  background: linear-gradient(180deg, rgba(255, 245, 244, 0.98), rgba(255, 251, 250, 0.98));
}

.inventory-item__icon {
  width: 64rpx;
  min-width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
}

.inventory-item__icon--ok {
  background: #2fc769;
  color: #fff;
}

.inventory-item__icon--missing {
  background: #fde8e6;
  color: #dc4b40;
}

.inventory-item__body {
  flex: 1;
  min-width: 0;
}

.inventory-item__name {
  font-size: 30rpx;
  font-weight: 800;
  color: #27323f;
}

.inventory-item__meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6c7788;
}

.inventory-item__status {
  flex: none;
  font-size: 28rpx;
  font-weight: 800;
}

.inventory-item__status--ok {
  color: var(--brand);
}

.inventory-item__status--missing {
  color: #dc4b40;
}

.inventory-item__checkbox {
  width: 44rpx;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #c9d5e3;
  background: #ffffff;
  color: transparent;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
  font-weight: 800;
}

.inventory-item__checkbox--selected {
  border-color: var(--brand);
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #ffffff;
}

.inventory-modal__primary {
  margin-top: 22rpx;
  min-height: 92rpx;
  border-radius: 999rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}
