.meal-plans-page {
  min-height: 100vh;
  padding: 32rpx 28rpx 140rpx;
  background: #f4f6fb;
  box-sizing: border-box;
}

.page-header {
  border-radius: 28rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #f9fbff 0%, #eaf1ff 100%);
  box-shadow: 0 14rpx 28rpx rgba(29, 53, 87, 0.08);
}

.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1b2432;
}

.page-summary {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #4f5f7a;
}

.page-space {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #5f7394;
}

.space-button {
  margin-top: 20rpx;
  background: #335d9f;
  color: #fff;
  font-size: 26rpx;
}

.error-text {
  margin-top: 20rpx;
  color: #b44343;
  font-size: 26rpx;
}

.empty-state {
  margin-top: 26rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  color: #1f2a3c;
  font-weight: 600;
}

.empty-text {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #63728a;
}

.empty-button {
  margin-top: 22rpx;
  background: #335d9f;
  color: #fff;
  font-size: 26rpx;
}

.group-card {
  margin-top: 22rpx;
  border-radius: 24rpx;
  padding: 20rpx;
  background: #ffffff;
}

.group-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3f63;
}

.group-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.fab-add {
  position: fixed;
  right: 28rpx;
  bottom: 34rpx;
  width: auto;
  padding: 0 28rpx;
  background: #2c5aa0;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  box-shadow: 0 12rpx 22rpx rgba(44, 90, 160, 0.25);
}
