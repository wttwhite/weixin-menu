page {
  height: 100%;
}

.recipes-page {
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 14rpx 18rpx calc(env(safe-area-inset-bottom) + 128rpx);
  overflow: hidden;
  background:
    radial-gradient(circle at top, var(--surface-muted, #e8edf1), transparent 30%),
    linear-gradient(180deg, var(--page-bg, #f6f7f8) 0%, #eef2f5 100%);
}

.hero-banner {
  position: relative;
  height: 154rpx;
  overflow: hidden;
  border-radius: 34rpx;
  box-shadow: 0 28rpx 46rpx rgba(71, 52, 35, 0.12);
}

.hero-banner__background {
  width: 100%;
  height: 100%;
}

.hero-banner__overlay {
  position: absolute;
  left: 16rpx;
  top: 14rpx;
  z-index: 4;
  color: #fff;
}

.hero-banner__date {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(0, 0, 0, 0.34);
  border-radius: 999rpx;
  text-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.24);
}

.hero-banner__thumbs {
  position: absolute;
  right: 18rpx;
  top: 12rpx;
  z-index: 2;
  display: flex;
  gap: 10rpx;
}

.hero-banner__thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.55);
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.12);
}

.management-card {
  margin-top: -90rpx;
  position: relative;
  z-index: 2;
  border-radius: 36rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 26rpx 42rpx rgba(56, 63, 79, 0.12);
}

.management-card__top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.management-card__cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: #f2f4f8;
}

.management-card__cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, #ff8a3d, #dc3737);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.management-card__meta {
  flex: 1;
  min-width: 0;
}

.management-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.management-card__count {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #2f8b37;
  font-weight: 700;
}

.management-card__summary {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a808d;
  line-height: 1.6;
}

.management-card__more {
  flex: none;
  width: auto;
  min-width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  margin: 0;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f4f5f8;
  color: #656d7a;
  font-size: 34rpx;
}

.management-card__actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.action-pill {
  flex: 1;
  min-height: 64rpx;
  padding: 0 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.action-pill--random {
  background: linear-gradient(135deg, #fed7aa 0%, #fb923c 55%, #fdba74 100%);
  color: #7c2d12;
  box-shadow: none;
}

.action-pill--create {
  background: var(--brand, #4f7d8a);
  color: #fff;
  box-shadow: none;
}

.feedback-card,
.empty-card {
  margin-top: 18rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 34rpx rgba(56, 63, 79, 0.1);
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.feedback-card--error {
  color: #8c2f2f;
}

.empty-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: #27323f;
}

.empty-card__text {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #7a808d;
}

.empty-card__button {
  margin-top: 20rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.empty-card--inline {
  margin-top: 0;
}

.channel-layout {
  display: flex;
  flex: 1;
  min-height: 0;
  gap: 16rpx;
  margin-top: 18rpx;
  align-items: stretch;
  overflow: hidden;
}

.channel-rail {
  display: flex;
  flex-direction: column;
  width: 134rpx;
  min-width: 134rpx;
  align-self: stretch;
  overflow: hidden;
  border-radius: 34rpx;
  background: rgba(230, 236, 244, 0.8);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.5);
}

.channel-rail__scroll {
  flex: 1;
  min-height: 0;
  height: 100%;
}

.channel-rail__scroll ::-webkit-scrollbar {
  display: none;
  width: 0;
}

.channel-rail__inner {
  padding: 14rpx 10rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.rail-item {
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 1.35;
  padding: 20rpx 10rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background: transparent;
  color: #7a808d;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  white-space: normal;
  overflow-wrap: anywhere;
}

.rail-item--active {
  background: #fff;
  color: var(--brand);
  box-shadow: 0 14rpx 24rpx rgba(102, 114, 138, 0.14);
}

.channel-column {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.channel-surface {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 34rpx;
  background: rgba(246, 248, 252, 0.92);
  box-shadow: inset 0 4rpx 10rpx rgba(255, 255, 255, 0.6);
}

.channel-surface__scroll {
  flex: 1;
  min-height: 0;
  height: auto;
  width: 100%;
  box-sizing: border-box;
  padding: 18rpx;
}

.channel-surface__scroll ::-webkit-scrollbar {
  display: none;
  width: 0;
}

.surface-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 0 4rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.surface-eyebrow {
  font-size: 22rpx;
  color: #7a808d;
}

.surface-title {
  margin-top: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.surface-meta {
  font-size: 22rpx;
  color: #7a808d;
}

.dish-list {
  display: grid;
  gap: 16rpx;
}

.dish-card {
  display: flex;
  gap: 16rpx;
  align-items: center;
  border-radius: 28rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 30rpx rgba(102, 114, 138, 0.14);
}

.dish-thumb {
  width: 132rpx;
  min-width: 132rpx;
}

.dish-thumb__image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 28rpx;
  background: #f2f4f8;
}

.dish-thumb__image--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, #ff9138, #dc3737);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.dish-body {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.dish-stars {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #f0b633;
  letter-spacing: 2rpx;
}

.dish-servings {
  margin-top: 2rpx;
  font-size: 37rpx;
  line-height: 1;
  font-weight: 700;
  color: var(--brand);
}

.dish-summary {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a808d;
  line-height: 1.5;
}

.dish-side {
  width: 72rpx;
  min-width: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.dish-usage {
  font-size: 20rpx;
  color: #9aa1ad;
}

.dish-add {
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--brand, #4f7d8a);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: none;
}

.dish-add--selected {
  background: var(--brand, #4f7d8a);
  color: #fff;
}

.dish-add__symbol {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.dish-add__symbol--selected {
  transform: translateY(1rpx);
}

.cart-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  border-radius: 30rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 20rpx 36rpx rgba(56, 63, 79, 0.16);
}

.cart-info {
  flex: 1;
  min-width: 0;
}

.cart-label {
  font-size: 22rpx;
  color: #7a808d;
}

.cart-count {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #27323f;
}

.cart-primary,
.cart-secondary {
  flex: none;
  width: auto;
  margin: 0;
  padding: 0 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.cart-primary {
  background: var(--brand, #4f7d8a);
  color: #fff;
}

.cart-secondary {
  background: #f2f4f8;
  color: #7a808d;
}

.plan-modal__overlay,
.category-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 50;
  padding: 120rpx 24rpx calc(env(safe-area-inset-bottom) + 150rpx);
  background: rgba(15, 23, 42, 0.24);
  backdrop-filter: blur(6rpx);
  box-sizing: border-box;
}

.plan-modal {
  border-radius: 34rpx;
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 26rpx 42rpx rgba(37, 49, 71, 0.18);
}

.plan-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.plan-modal__title {
  font-size: 34rpx;
  font-weight: 800;
  color: #182234;
}

.plan-modal__close {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f2f4f8;
  color: #7a808d;
}

.plan-modal__section {
  margin-top: 24rpx;
}

.plan-modal__label {
  font-size: 24rpx;
  color: #7a808d;
}

.plan-modal__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.plan-modal__tag {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-muted, #f3f4f7);
  color: var(--text-primary, #27323f);
  font-size: 28rpx;
  font-weight: 700;
}

.plan-modal__date {
  margin-top: 14rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fbfcfe;
  border: 1px solid #edf1f5;
  font-size: 30rpx;
  font-weight: 700;
  color: #27323f;
}

.plan-modal__date-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.plan-modal__date-chip {
  min-width: 128rpx;
  padding: 16rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #7a808d;
  background: #f4f6fa;
}

.plan-modal__date-chip--active {
  color: var(--brand, #4f7d8a);
  background: var(--surface-muted, #f3f4f7);
}

.plan-modal__meal-types {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.plan-modal__meal-chip {
  min-width: 128rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #7a808d;
  background: #f4f6fa;
}

.plan-modal__meal-chip--active {
  color: var(--brand, #4f7d8a);
  background: var(--surface-muted, #f3f4f7);
}

.plan-modal__actions {
  display: flex;
  gap: 14rpx;
  margin-top: 28rpx;
}

.plan-modal__primary,
.plan-modal__secondary {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.plan-modal__primary {
  background: var(--surface-muted, #f3f4f7);
  color: var(--brand, #4f7d8a);
}

.plan-modal__secondary {
  background: #f2f4f8;
  color: #7a808d;
}

.category-modal {
  border-radius: 34rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 26rpx 42rpx rgba(37, 49, 71, 0.18);
}

.category-modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.category-modal__title {
  font-size: 52rpx;
  font-weight: 800;
  color: #182234;
}

.category-modal__close,
.category-modal__edit,
.category-modal__delete,
.category-modal__drag {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-modal__close,
.category-modal__drag {
  background: #f2f4f8;
  color: #7a808d;
}

.category-modal__input-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.category-modal__input {
  flex: 1;
  height: 44px;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 1px solid #edf0f4;
  background: #fff;
  font-size: 28rpx;
}

.category-modal__confirm {
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.category-modal__hint {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #7a808d;
}

.category-modal__list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.category-modal__item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 20rpx;
  background: #fbfcfe;
  border: 1px solid #edf1f5;
}

.category-modal__name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #27323f;
}

.category-modal__actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.category-modal__edit {
  background: #eef5ff;
  color: #4d7edc;
}

.category-modal__count {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4f5f8;
  color: #8b95a3;
  font-size: 22rpx;
}

.category-modal__delete {
  background: #ffe9e9;
  color: #d14b4b;
}
