.recipes-page {
  min-height: 100vh;
  padding: 36rpx 28rpx 60rpx;
}

.recipes-hero {
  border-radius: 36rpx;
  padding: 40rpx 34rpx;
  background:
    linear-gradient(150deg, rgba(63, 45, 30, 0.96), rgba(130, 86, 45, 0.92)),
    var(--surface-strong);
  color: #fff;
  box-shadow: var(--shadow-soft);
}

.recipes-kicker {
  font-size: 24rpx;
  letter-spacing: 3rpx;
  color: rgba(255, 255, 255, 0.72);
}

.recipes-title {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 600;
}

.recipes-text {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
}

.recipes-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.recipes-button {
  flex: 1;
  padding: 22rpx 0;
  background: #fff;
  color: #473423;
  font-size: 28rpx;
}

.recipes-button--ghost {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
}

.feedback-card,
.empty-card,
.quick-links {
  margin-top: 24rpx;
  border-radius: 28rpx;
  padding: 24rpx;
  background: var(--surface-bg);
  box-shadow: var(--shadow-soft);
}

.feedback-card {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.feedback-card--error {
  color: #8c2f2f;
}

.recipe-list {
  margin-top: 24rpx;
  display: grid;
  gap: 18rpx;
}

.empty-card__title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-card__text {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.empty-card__button {
  margin-top: 24rpx;
  padding: 22rpx 0;
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
}

.quick-link {
  background: #fff;
  color: var(--text-secondary);
  font-size: 26rpx;
}
