<view class="recipes-page" style="{{themeStyle}}">
  <view class="hero-banner">
    <image class="hero-banner__background" src="/images/food-hero-table.svg" mode="aspectFill" />
    <view class="hero-banner__overlay">
      <view class="hero-banner__date">{{currentDateLabel}}</view>
    </view>
    <view wx:if="{{showHeroThumbs}}" class="hero-banner__thumbs">
      <image
        wx:for="{{heroThumbImages}}"
        wx:key="index"
        class="hero-banner__thumb"
        src="{{item}}"
        mode="aspectFill"
      />
    </view>
  </view>

  <view class="management-card">
    <view class="management-card__top">
      <image
        wx:if="{{managementImageUrl}}"
        class="management-card__cover"
        src="{{managementImageUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="management-card__cover management-card__cover--placeholder">热卖</view>

      <view class="management-card__meta">
        <view class="management-card__title">菜谱管理</view>
        <view class="management-card__count">{{managementRecipeCountText}}</view>
        <view class="management-card__summary">{{managementCategorySummary}}</view>
      </view>

      <view class="management-card__more" bindtap="openSpaceManager">⋮</view>
    </view>

    <view class="management-card__actions">
      <view class="action-pill action-pill--random" bindtap="handleRandomPick">🎲 随机点菜</view>
      <view class="action-pill action-pill--create" bindtap="goCreate">＋ 新增菜谱</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>
  <view wx:if="{{!errorMessage && truncationMessage}}" class="feedback-card">{{truncationMessage}}</view>
  <view wx:if="{{!errorMessage && loading}}" class="feedback-card">正在加载菜谱...</view>

  <view wx:elif="{{!activeSpaceId}}" class="empty-card">
    <view class="empty-card__title">先选择一个空间</view>
    <view class="empty-card__text">空间用于团队共享菜谱、库存、计划和采购数据。</view>
    <t-button class="empty-card__button" theme="primary" block bindtap="openSpace">前往选择空间</t-button>
  </view>

  <view wx:else class="channel-layout">
    <view class="channel-rail">
      <scroll-view class="channel-rail__scroll" scroll-y="true" show-scrollbar="{{false}}" style="height:{{railScrollHeight}}px">
        <view class="channel-rail__inner">
          <view
            wx:for="{{sectionViewItems}}"
            wx:key="key"
            class="{{item.itemClass}}"
            data-key="{{item.key}}"
            bindtap="handleSectionChange"
          >
            {{item.label}}
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="channel-column">
      <view class="surface-head">
        <view>
          <view class="surface-eyebrow">菜谱频道</view>
          <view class="surface-title">{{activeSectionLabel}}</view>
        </view>
        <view class="surface-meta">{{visibleItemsCountText}}</view>
      </view>

      <view class="channel-surface">
        <scroll-view class="channel-surface__scroll" scroll-y="{{showVisibleItems}}" show-scrollbar="{{false}}" style="height:{{surfaceScrollHeight}}px">
          <view wx:if="{{showVisibleItems}}" class="dish-list">
            <view wx:for="{{visibleItems}}" wx:key="_id" class="dish-card">
              <view class="dish-thumb" data-recipe-id="{{item._id}}" bindtap="openRecipeFromCard">
                <image
                  wx:if="{{item.coverImageUrl}}"
                  class="dish-thumb__image"
                  src="{{item.coverImageUrl}}"
                  mode="aspectFill"
                />
                <view wx:else class="dish-thumb__image dish-thumb__image--placeholder">热卖</view>
              </view>

              <view class="dish-body" data-recipe-id="{{item._id}}" bindtap="openRecipeFromCard">
                <view class="dish-name">{{item.name}}</view>
                <view wx:if="{{item.recommendationStars}}" class="dish-stars">{{item.recommendationStars}}</view>
                <view class="dish-servings">{{item.servingsDisplay}}</view>
                <view class="dish-summary">{{item.summaryDisplay}}</view>
              </view>

              <view class="dish-side">
                <view class="dish-usage">月销 {{item.planUsageCount}}</view>
                <view
                  class="{{item.selectionClass}}"
                  data-recipe-id="{{item._id}}"
                  bindtap="toggleRecipeSelection"
                >
                  <text class="dish-add__symbol {{item.selected ? 'dish-add__symbol--selected' : ''}}">{{item.selectionSymbol}}</text>
                </view>
              </view>
            </view>
          </view>

          <view wx:else class="empty-card empty-card--inline">
            <view class="empty-card__title">{{emptyTitle}}</view>
            <view class="empty-card__text">{{emptyText}}</view>
            <t-button class="empty-card__button" theme="primary" block bindtap="goCreate">{{emptyButtonText}}</t-button>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <view class="cart-bar">
    <view class="cart-info">
      <view class="cart-label">已选菜谱</view>
      <view class="cart-count">{{selectedRecipesCount}} 道菜</view>
    </view>
    <view class="cart-primary" bindtap="handlePlanSelectedRecipes">📅 加入计划</view>
    <view class="cart-secondary" bindtap="clearSelectedRecipes">清空</view>
  </view>

  <view wx:if="{{showPlanModal}}" class="plan-modal__overlay" catchtap="closePlanModal">
    <view class="plan-modal" catchtap="noop">
      <view class="plan-modal__header">
        <view class="plan-modal__title">加入计划</view>
        <view class="plan-modal__close" bindtap="closePlanModal">×</view>
      </view>

      <view class="plan-modal__section">
        <view class="plan-modal__label">已选 {{selectedRecipesCount}} 道菜</view>
        <view class="plan-modal__tags">
          <view wx:for="{{planModalSelectedRecipes}}" wx:key="_id" class="plan-modal__tag">{{item.name}}</view>
        </view>
      </view>

      <view class="plan-modal__section">
        <view class="plan-modal__label">选择日期</view>
        <view class="plan-modal__date-options">
          <view
            wx:for="{{planModalDateOptions}}"
            wx:key="value"
            class="plan-modal__date-chip {{item.value === planModalDate ? 'plan-modal__date-chip--active' : ''}}"
            data-date="{{item.value}}"
            bindtap="handlePlanDateShortcutSelect"
          >
            {{item.label}}
          </view>
        </view>
        <picker mode="date" value="{{planModalDate}}" bindchange="handlePlanDateChange">
          <view class="plan-modal__date">{{planModalDate}}</view>
        </picker>
      </view>

      <view class="plan-modal__section">
        <view class="plan-modal__label">餐次</view>
        <view class="plan-modal__meal-types">
          <view
            wx:for="{{planModalMealTypeOptions}}"
            wx:key="value"
            class="plan-modal__meal-chip {{item.value === planModalMealType ? 'plan-modal__meal-chip--active' : ''}}"
            data-meal-type="{{item.value}}"
            bindtap="handlePlanMealTypeChange"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="plan-modal__actions">
        <view class="plan-modal__secondary" bindtap="closePlanModal">取消</view>
        <view class="plan-modal__primary" bindtap="submitPlanSelection">添加到 {{planModalDate}}</view>
      </view>
    </view>
  </view>

  <recipe-category-manager-modal
    visible="{{showCategoryManager}}"
    loading="{{categoryManagerLoading}}"
    input-value="{{categoryManagerInput}}"
    items="{{categoryManagerViewItems}}"
    dragging-index="{{categoryManagerDraggingIndex}}"
    bind:close="closeCategoryManager"
    bind:inputchange="handleCategoryManagerInput"
    bind:submit="submitCategoryManagerCreate"
    bind:rename="renameCategory"
    bind:delete="deleteCategory"
    bind:dragstart="handleCategoryManagerDragStart"
    bind:dragmove="handleCategoryManagerDragMove"
    bind:dragend="handleCategoryManagerDragEnd"
    bind:dragcancel="handleCategoryManagerDragCancel"
  />
</view>
