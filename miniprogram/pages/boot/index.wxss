.boot-page {
  min-height: 100vh;
  padding: 80rpx 40rpx;
  background:
    radial-gradient(circle at top left, rgba(197, 106, 61, 0.18), transparent 34%),
    linear-gradient(180deg, #f8f2e8 0%, #f1e4cf 100%);
}

.boot-card {
  margin-top: 240rpx;
  border-radius: 40rpx;
  padding: 52rpx 40rpx;
  background: rgba(255, 250, 240, 0.9);
  box-shadow: var(--shadow-soft);
}

.boot-badge {
  display: inline-flex;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--brand-strong);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.boot-title {
  margin-top: 28rpx;
  font-size: 46rpx;
  font-weight: 600;
  line-height: 1.3;
}

.boot-detail {
  margin-top: 18rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.boot-loading {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.loading-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--brand);
  animation: pulse 1.1s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.boot-action {
  margin-top: 40rpx;
  padding: 24rpx 0;
  background: var(--brand);
  color: #fff;
  font-size: 28rpx;
}

.boot-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

.boot-actions .boot-action {
  margin-top: 0;
}

.boot-action-secondary {
  background: transparent;
  color: var(--brand-strong);
  border: 2rpx solid rgba(157, 86, 46, 0.22);
 }

@keyframes pulse {
  0%,
  100% {
    opacity: 0.35;
    transform: translateY(0);
  }

  50% {
    opacity: 1;
    transform: translateY(-8rpx);
  }
}
