.boot-page {
  min-height: 100vh;
  padding: 80rpx 40rpx;
  background:
    radial-gradient(circle at top left, rgba(197, 106, 61, 0.18), transparent 34%),
    linear-gradient(180deg, #f8f2e8 0%, #f1e4cf 100%);
}

.boot-card {
  margin-top: 240rpx;
  border-radius: 40rpx;
  padding: 52rpx 40rpx;
  background: rgba(255, 250, 240, 0.9);
  box-shadow: var(--shadow-soft);
}

.boot-badge {
  display: inline-flex;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: var(--surface-muted);
  color: var(--brand-strong);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.boot-title {
  margin-top: 28rpx;
  font-size: 46rpx;
  font-weight: 600;
  line-height: 1.3;
}

.boot-detail {
  margin-top: 18rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.7;
}

.boot-loading {
  display: flex;
  justify-content: center;
  margin-top: 48rpx;
  color: var(--brand);
}

.boot-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* TDesign button 品牌色覆盖 */
.boot-actions t-button {
  --td-brand-color: var(--brand);
  --td-brand-color-active: var(--brand-strong);
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-outline-color: var(--brand);
  --td-button-primary-outline-border-color: var(--brand);
}
