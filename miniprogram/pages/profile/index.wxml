<view class="profile-page" style="{{themeStyle}}">
  <view class="profile-hero">
    <view class="profile-hero__body">
      <view class="profile-hero__kicker">Profile Center</view>
      <view class="profile-hero__title-row">
        <view class="profile-hero__title-text">{{currentDisplayName || '个人中心'}}</view>
        <view class="profile-hero__edit-trigger" bindtap="handleEditDisplayName">
          <view class="profile-hero__edit-icon">✎</view>
        </view>
      </view>
      <view class="profile-hero__subtitle">{{activeSpaceName || '尚未选择空间'}} · {{roleLabel || '成员'}}</view>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>

  <view wx:elif="{{showEmptyState}}" class="feedback-card">
    当前还没有可用空间，先创建空间或使用邀请码加入空间。
  </view>

  <view wx:else>
    <view class="summary-grid">
      <view class="summary-card">
        <view class="summary-card__label">成员</view>
        <view class="summary-card__value">{{memberCountText}}</view>
      </view>
      <view class="summary-card">
        <view class="summary-card__label">菜谱</view>
        <view class="summary-card__value">{{recipeCountText}}</view>
      </view>
      <view class="summary-card">
        <view class="summary-card__label">备份</view>
        <view class="summary-card__meta">{{backupStatusText}}</view>
      </view>
    </view>

    <view class="space-card">
      <view class="space-card__head">
        <view>
          <view class="space-card__title">{{activeSpaceName || '未命名空间'}}</view>
          <view class="space-card__meta">{{roleLabel}} · {{spacesCountText}}</view>
        </view>
        <view class="space-card__invite">{{inviteCode || '暂无邀请码'}}</view>
      </view>
      <view class="space-card__actions">
        <t-button class="space-card__button" theme="primary" size="small" shape="round" bindtap="handleCopyInviteCode">复制邀请码</t-button>
      </view>
      <view class="space-card__links">
        <view wx:if="{{canRenameSpace}}" class="space-chip space-chip--accent" bindtap="handleRenameSpace">修改空间名</view>
        <view class="space-chip" bindtap="openSpace">切换空间</view>
        <view class="space-chip" bindtap="openCreateSpace">创建空间</view>
        <view class="space-chip" bindtap="openJoinSpace">加入空间</view>
      </view>
    </view>

    <view class="profile-section">
      <view class="profile-section__title">空间与成员</view>
      <view class="action-row" bindtap="openMembers">
        <view class="action-row__icon">👥</view>
        <view class="action-row__body">
          <view class="action-row__title">成员管理</view>
          <view class="action-row__desc">邀请、编辑昵称、移除成员</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
    </view>

    <view class="profile-section">
      <view class="profile-section__title">内容配置</view>
      <view class="action-row" bindtap="openRecipeCategoryManager">
        <view class="action-row__icon">🥗</view>
        <view class="action-row__body">
          <view class="action-row__title">菜谱分类</view>
          <view class="action-row__desc">维护菜谱分类名称与可删状态</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
      <view class="action-row" bindtap="openPantryCategoryManager">
        <view class="action-row__icon">🥬</view>
        <view class="action-row__body">
          <view class="action-row__title">食材分类</view>
          <view class="action-row__desc">统一库存分类管理</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
      <view class="action-row" bindtap="openPantryLocationManager">
        <view class="action-row__icon">📍</view>
        <view class="action-row__body">
          <view class="action-row__title">食材位置</view>
          <view class="action-row__desc">维护冷藏、橱柜等位置</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
      <view class="action-row" bindtap="openThemeModal">
        <view class="action-row__icon">🎨</view>
        <view class="action-row__body">
          <view class="action-row__title">换肤</view>
          <view class="action-row__desc">切换暖色、冷蓝、海盐与樱粉主题</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
    </view>

    <view class="profile-section">
    <view class="profile-section__title">数据与分析</view>
    <view class="action-row" bindtap="openBackup">
      <view class="action-row__icon">💾</view>
      <view class="action-row__body">
          <view class="action-row__title">数据备份</view>
          <view class="action-row__desc">导出备份或进入导入页面</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
      <view class="action-row" bindtap="openStatistics">
        <view class="action-row__icon">📊</view>
        <view class="action-row__body">
          <view class="action-row__title">统计</view>
          <view class="action-row__desc">查看菜谱、库存和采购进展</view>
        </view>
        <view class="action-row__arrow">›</view>
      </view>
    </view>
  </view>

  <recipe-category-manager-modal
    visible="{{showRecipeCategoryManager}}"
    loading="{{recipeCategoryManagerLoading}}"
    input-value="{{recipeCategoryManagerInput}}"
    items="{{recipeCategoryManagerItems}}"
    bind:close="closeRecipeCategoryManager"
    bind:inputchange="handleRecipeCategoryManagerInput"
    bind:submit="submitRecipeCategoryManagerCreate"
    bind:rename="renameRecipeCategoryManagerItem"
    bind:delete="deleteRecipeCategoryManagerItem"
  />

  <pantry-manager-modal
    visible="{{showPantryManagerModal}}"
    title="{{pantryManagerTitle}}"
    meta-text="{{pantryManagerMetaText}}"
    input-placeholder="{{pantryManagerInputPlaceholder}}"
    input-value="{{pantryManagerInput}}"
    loading="{{pantryManagerLoading}}"
    loading-text="{{pantryManagerLoadingText}}"
    items="{{pantryManagerItems}}"
    dragging-index="{{pantryManagerDraggingIndex}}"
    empty-illustration="{{pantryManagerEmptyIllustration}}"
    empty-illustration-class="{{pantryManagerEmptyIllustrationClass}}"
    empty-title="{{pantryManagerEmptyTitle}}"
    empty-text="{{pantryManagerEmptyText}}"
    bind:close="closePantryManagerModal"
    bind:inputchange="handlePantryManagerInput"
    bind:submit="submitPantryManagerCreate"
    bind:rename="renamePantryManagerItem"
    bind:delete="deletePantryManagerItem"
    bind:dragstart="handlePantryManagerDragStart"
    bind:dragmove="handlePantryManagerDragMove"
    bind:dragend="handlePantryManagerDragEnd"
    bind:dragcancel="handlePantryManagerDragCancel"
  />

  <view wx:if="{{showThemeModal}}" class="theme-modal" catchtap="closeThemeModal" catchtouchmove="noop">
    <view class="theme-modal__panel" catchtap="noop" catchtouchmove="noop">
      <view class="theme-modal__title">换肤</view>
      <view class="theme-chip-list">
        <view
          wx:for="{{themeOptions}}"
          wx:key="key"
          class="theme-chip {{item.active ? 'theme-chip--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectTheme"
        >
          <view class="theme-chip__main">
            <view class="theme-chip__copy">
              <view class="theme-chip__title">{{item.label}}</view>
              <view class="theme-chip__desc">{{item.description}}</view>
            </view>
            <view class="theme-chip__swatches">
              <view
                wx:for="{{item.swatches}}"
                wx:key="*this"
                wx:for-item="swatch"
                class="theme-chip__swatch"
                style="background: {{swatch}};"
              ></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
