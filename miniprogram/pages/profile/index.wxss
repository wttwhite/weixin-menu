.profile-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 28rpx 24rpx calc(env(safe-area-inset-bottom) + 160rpx);
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.7), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.38), transparent 26%),
    var(--page-bg);
}

.profile-hero {
  position: relative;
  overflow: hidden;
  padding: 28rpx 26rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 86% 18%, var(--hero-soft-glow, rgba(255, 255, 255, 0.46)), transparent 18%),
    radial-gradient(circle at 16% 12%, var(--hero-soft-glow-weak, rgba(255, 255, 255, 0.22)), transparent 20%),
    linear-gradient(145deg, var(--hero-soft-start, #edf5f7) 0%, var(--hero-soft-end, #d9eaee) 100%);
  color: var(--hero-soft-text, #24414a);
  box-shadow: var(--shadow-soft, 0 18rpx 40rpx rgba(63, 50, 38, 0.08));
}

.profile-hero::before {
  content: '';
  position: absolute;
  left: 20rpx;
  bottom: 18rpx;
  width: 180rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0));
  opacity: 0.7;
  transform: rotate(-8deg);
}

.profile-hero::after {
  content: '';
  position: absolute;
  right: -24rpx;
  top: 44rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, var(--hero-soft-glow-weak, rgba(255, 255, 255, 0.22)), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.profile-hero__body {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.profile-hero__kicker {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  color: var(--hero-soft-subtle, #6e8790);
}

.profile-hero__title-row {
  margin-top: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.profile-hero__title-text {
  flex: 1;
  min-width: 0;
  font-size: 44rpx;
  line-height: 1.08;
  font-weight: 800;
  color: var(--hero-soft-text, #24414a);
  word-break: break-all;
}

.profile-hero__edit-trigger {
  flex: none;
  width: 58rpx;
  min-width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--hero-soft-chip-bg, rgba(255, 255, 255, 0.62));
  box-shadow: inset 0 0 0 1px var(--hero-soft-chip-border, rgba(255, 255, 255, 0.34));
}

.profile-hero__edit-icon {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--hero-soft-text, #24414a);
}

.profile-hero__subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #5c6872);
}

.feedback-card,
.space-card,
.profile-section,
.summary-card {
  margin-top: 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: var(--shadow-soft);
}

.feedback-card {
  padding: 24rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.feedback-card--error {
  color: #8c2f2f;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 20rpx;
}

.summary-card {
  margin-top: 0;
  padding: 22rpx 20rpx;
}

.summary-card__label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.summary-card__value {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.summary-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.space-card {
  padding: 28rpx 24rpx;
}

.space-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.space-card__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.space-card__meta,
.space-card__invite {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.space-card__invite {
  flex: none;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
}

.space-card__actions,
.space-card__links {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.space-card__button {
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.space-card__button--ghost {
  --td-button-outline-primary-color: var(--brand);
  --td-button-outline-primary-border-color: var(--brand);
}

.space-chip {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: var(--text-primary);
  font-size: 24rpx;
}

.space-chip--accent {
  background: rgba(255, 255, 255, 0.86);
  color: var(--brand-strong);
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.46);
}

.profile-section {
  padding: 18rpx 18rpx 6rpx;
}

.profile-section__title {
  padding: 10rpx 12rpx 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.action-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.action-row__icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  font-size: 34rpx;
}

.action-row__body {
  flex: 1;
  min-width: 0;
}

.action-row__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.action-row__desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.action-row__arrow {
  color: var(--text-tertiary);
  font-size: 34rpx;
}

.theme-modal {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(21, 28, 40, 0.28);
  backdrop-filter: blur(8rpx);
}

.theme-modal__panel {
  width: 100%;
  max-width: 680rpx;
  max-height: 76vh;
  overflow: auto;
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: var(--shadow-soft);
}

.theme-modal__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.theme-chip-list {
  display: grid;
  gap: 14rpx;
  margin-top: 18rpx;
}

.theme-chip {
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(245, 246, 249, 0.96);
  border: 2rpx solid transparent;
}

.theme-chip--active {
  border-color: var(--brand);
  box-shadow: inset 0 0 0 2rpx rgba(0, 0, 0, 0.02);
}

.theme-chip__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.theme-chip__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.theme-chip__main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.theme-chip__copy {
  flex: 1;
  min-width: 0;
}

.theme-chip__swatches {
  flex: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.theme-chip__swatch {
  width: 22rpx;
  min-width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.42), 0 2rpx 6rpx rgba(31, 49, 37, 0.08);
}
