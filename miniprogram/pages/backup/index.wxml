<view class="backup-page" style="{{themeStyle}}">
  <view class="backup-hero">
    <view class="backup-title">数据备份</view>
    <view class="backup-text">导出或导入当前空间的结构化数据与图片文件。</view>
    <view class="backup-actions">
      <t-button class="backup-btn" theme="primary" loading="{{exporting}}" bindtap="handleExport">导出备份</t-button>
      <t-button wx:if="{{role === 'owner'}}" class="backup-btn backup-btn--ghost" variant="outline" loading="{{importing}}" bindtap="handleImport">导入备份</t-button>
    </view>
  </view>

  <view wx:if="{{errorMessage}}" class="feedback-card feedback-card--error">{{errorMessage}}</view>
  <view wx:elif="{{loading}}" class="feedback-card">正在加载备份记录...</view>

  <view wx:elif="{{records.length}}" class="records-list">
    <view wx:for="{{records}}" wx:key="_id" class="record-card">
      <view class="record-card__type">{{item.type}}</view>
      <view class="record-card__status">{{item.status}}</view>
      <view wx:if="{{item.fileName}}" class="record-card__time">{{item.fileName}}</view>
      <view class="record-card__time">{{item.updatedAt || item.createdAt}}</view>
      <t-button
        wx:if="{{item.fileId}}"
        class="record-card__button"
        theme="primary"
        variant="outline"
        size="small"
        data-file-id="{{item.fileId}}"
        bindtap="handleCopyRecordUrl"
      >
        复制下载链接
      </t-button>
    </view>
  </view>

  <view wx:else class="feedback-card">当前空间还没有备份记录。</view>
</view>
