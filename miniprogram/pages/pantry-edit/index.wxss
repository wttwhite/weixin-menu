.edit-page {
  min-height: 100vh;
  overflow-x: hidden;
  padding: 28rpx 24rpx 180rpx;
  background:
    radial-gradient(circle at top, rgba(135, 203, 158, 0.18), transparent 28%),
    linear-gradient(180deg, #f7faf8 0%, #edf2ef 100%);
}

.editor-shell,
.state-card {
  display: grid;
  gap: 22rpx;
  min-width: 0;
}

.editor-section,
.state-card {
  border-radius: 34rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 34rpx rgba(56, 63, 79, 0.1);
  min-width: 0;
}

.state-title,
.editor-section__title {
  font-size: 46rpx;
  font-weight: 800;
  color: #182234;
}

.state-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #7a808d;
}

.state-button {
  margin-top: 20rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.editor-section__icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(197, 106, 61, 0.12);
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 700;
}

.editor-section__icon--danger {
  background: #ffe9e9;
  color: #d14b4b;
}

.editor-section__divider {
  height: 1px;
  margin: 18rpx 0 8rpx;
  background: #edf1f5;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  min-width: 0;
}

.form-row__label {
  width: 124rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #27323f;
  white-space: nowrap;
}

.form-row__required {
  margin-right: 6rpx;
  color: #d65a5a;
}

.field-label {
  margin-top: 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #27323f;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  border-radius: 18rpx;
  background: #fafbfe;
  border: 1px solid #edf0f4;
  font-size: 28rpx;
  line-height: 1.4;
  color: #27323f;
}

.field-input--inline {
  margin-top: 0;
  flex: 1;
  width: auto;
  min-width: 0;
}

.picker-field {
  flex: 1;
  min-width: 0;
}

.field-picker-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.field-input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
}

.field-input--date {
  display: flex;
  align-items: center;
}

.field-input--picker,
.field-input--readonly {
  justify-content: space-between;
}

.field-input--readonly {
  color: #667084;
  background: #f4f7fa;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.detail-grid__item {
  min-width: 0;
}

.quantity-stepper {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 100%;
  min-width: 0;
}

.quantity-stepper--inline {
  margin-top: 12rpx;
}

.stepper-button {
  width: 48rpx;
  min-width: 48rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 14rpx;
  background: rgba(197, 106, 61, 0.12);
  color: var(--brand);
  font-size: 30rpx;
  font-weight: 700;
}

.stepper-button::after {
  border: none;
}

.stepper-value {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 12rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #fafbfe;
  border: 1px solid #edf0f4;
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
  text-align: center;
}

.date-row__picker {
  display: block;
  width: 100%;
  min-width: 0;
  margin-top: 10rpx;
}

.field-clear {
  flex: none;
  width: auto;
  min-width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  margin-top: 0;
  border-radius: 999rpx;
  background: #eef3ef;
  color: #667084;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.description-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.description-head__label {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.description-head__count {
  font-size: 22rpx;
  color: #8c95a2;
}

.field-textarea {
  padding: 18rpx 24rpx;
  line-height: 1.6;
}

.field-textarea--notes {
  min-height: 80rpx;
  height: 80rpx;
}

.delete-button {
  margin-top: 6rpx;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 14rpx);
  display: flex;
  gap: 14rpx;
}

.footer-close-btn {
  width: 170rpx;
  --td-button-default-bg-color: #edf1f6;
  --td-button-default-color: #27323f;
  --td-button-default-border-color: transparent;
}

.footer-submit-btn {
  flex: 1;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}
