.edit-page {
  min-height: 100vh;
  overflow-x: hidden;
  padding: 28rpx 24rpx 180rpx;
  background:
    radial-gradient(circle at top, rgba(135, 203, 158, 0.18), transparent 28%),
    linear-gradient(180deg, #f7faf8 0%, #edf2ef 100%);
}

.editor-shell,
.detail-shell,
.state-card {
  display: grid;
  gap: 22rpx;
  min-width: 0;
}

.detail-page {
  min-height: 100vh;
  overflow-x: hidden;
  padding: 20rpx 20rpx 160rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top, rgba(135, 203, 158, 0.18), transparent 28%),
    linear-gradient(180deg, #f7faf8 0%, #edf2ef 100%);
}

.detail-content {
  display: grid;
  gap: 18rpx;
}

.editor-section,
.state-card {
  border-radius: 34rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 20rpx 34rpx rgba(56, 63, 79, 0.1);
  min-width: 0;
}

.hero-card,
.card {
  border-radius: 30rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 18rpx 30rpx rgba(56, 63, 79, 0.12);
}

.hero-card {
  position: relative;
  overflow: hidden;
  min-height: 300rpx;
  padding: 0;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.22), transparent 24%),
    linear-gradient(135deg, #3f6c4f 0%, #5b936d 54%, #89be91 100%);
}

.hero-overlay {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  z-index: 1;
  color: #fff;
}

.hero-overlay--plain {
  top: 22rpx;
  bottom: 22rpx;
  display: flex;
  align-items: flex-end;
}

.hero-copy-panel {
  max-width: 88%;
  display: grid;
  gap: 10rpx;
  justify-items: start;
}

.hero-badge {
  display: inline-flex;
  justify-self: start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(10, 18, 28, 0.36);
  border: 1px solid rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(14rpx);
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  display: inline-flex;
  padding: 10rpx 16rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(10, 16, 28, 0.42);
  border: 1px solid rgba(255, 255, 255, 0.14);
  backdrop-filter: blur(14rpx);
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 800;
  text-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.28);
}

.hero-summary {
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(10, 16, 28, 0.38);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
}

.hero-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 14rpx;
}

.hero-metric {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(12, 20, 34, 0.42);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
  font-size: 28rpx;
  font-weight: 700;
}

.action-row {
  display: flex;
  gap: 14rpx;
}

.t-button.action-btn {
  flex: 1;
  width: auto;
  min-width: 0;
  margin-left: 0;
  margin-right: 0;
  margin: 0;
  --td-button-height: 96rpx;
  --td-button-font-size: 34rpx;
}

.t-button.action-btn--edit {
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.t-button.action-btn--delete {
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.card-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 16rpx;
}

.card-head__left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-head__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef3ff;
}

.card-head__meta {
  flex: none;
  text-align: right;
  font-size: 28rpx;
  font-weight: 700;
  color: #8d96a3;
}

.card-title {
  min-width: 0;
  font-size: 38rpx;
  font-weight: 800;
  color: #182234;
}

.card-divider {
  height: 1px;
  margin: 18rpx 0 16rpx;
  background: #edf1f5;
}

.card-text {
  font-size: 28rpx;
  color: #7a808d;
  line-height: 1.7;
}

.detail-pair-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.detail-pair {
  padding: 18rpx 18rpx 20rpx;
  border-radius: 24rpx;
  background: #f7f9fd;
}

.detail-pair__label {
  font-size: 22rpx;
  color: #8d96a3;
}

.detail-pair__value {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #27323f;
}

.state-title,
.editor-section__title {
  font-size: 46rpx;
  font-weight: 800;
  color: #182234;
}

.state-text {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #7a808d;
}

.state-button {
  margin-top: 20rpx;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.editor-section__icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(197, 106, 61, 0.12);
  color: var(--brand);
  font-size: 26rpx;
  font-weight: 700;
}

.editor-section__icon--danger {
  background: #ffe9e9;
  color: #d14b4b;
}

.editor-section__head {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.editor-section__divider {
  height: 1px;
  margin: 18rpx 0 8rpx;
  background: #edf1f5;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.detail-edit-button {
  flex: none;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

.form-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  min-width: 0;
}

.form-row__label {
  width: 96rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #27323f;
  white-space: nowrap;
}

.editor-section__title {
  min-width: 0;
  white-space: nowrap;
}

.form-row__required {
  margin-right: 6rpx;
  color: #d65a5a;
}

.field-label {
  margin-top: 22rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #27323f;
}

.field-input,
.field-textarea,
.category-picker__value {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  border-radius: 18rpx;
  background: #fafbfe;
  border: 1px solid #edf0f4;
  font-size: 28rpx;
  line-height: 1.4;
  color: #27323f;
}

.field-input--inline {
  margin-top: 0;
  flex: 1;
  width: auto;
  min-width: 0;
}

.picker-field {
  flex: 1;
  min-width: 0;
}

.category-picker {
  flex: 1;
  min-width: 0;
}

.category-picker__value {
  margin-top: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.category-picker__value--placeholder {
  color: #b6bdc8;
}

.category-picker__arrow {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-right: 3rpx solid #a1a8b3;
  border-bottom: 3rpx solid #a1a8b3;
  transform: rotate(45deg);
}

.field-picker-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: stretch;
  gap: 10rpx;
  position: relative;
}

.field-input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
}

.field-input--date {
  height: 88rpx;
  display: flex;
  align-items: center;
}

.field-input--with-clear {
  padding-right: 72rpx;
}

.field-input--picker,
.field-input--readonly {
  justify-content: space-between;
}

.field-input--readonly {
  color: #667084;
  background: #f4f7fa;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.detail-grid--basic,
.detail-grid--schedule {
  margin-top: 22rpx;
}

.detail-grid__item {
  display: grid;
  align-content: start;
  min-width: 0;
}

.detail-grid__item .field-label {
  margin-top: 0;
}

.field-label--tight {
  margin-top: 0;
}

.quantity-stepper {
  margin-top: 10rpx;
  display: flex;
  align-items: stretch;
  gap: 0;
  width: 100%;
  min-width: 0;
  border-radius: 18rpx;
  overflow: hidden;
  border: 1px solid #edf0f4;
  background: #fafbfe;
}

.quantity-stepper--inline {
  margin-top: 10rpx;
}

.stepper-button {
  flex: none;
  width: 88rpx;
  min-width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafbfe;
  border: 0;
  color: #667084;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.stepper-value {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: #fafbfe;
  border: 0;
  border-left: 1px solid #edf0f4;
  border-right: 1px solid #edf0f4;
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
  text-align: center;
}

.date-row__picker {
  display: block;
  width: 100%;
  min-width: 0;
  margin-top: 10rpx;
}

.field-clear {
  position: absolute;
  right: 18rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 40rpx;
  min-width: 40rpx;
  height: 40rpx;
  margin-top: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 112, 132, 0.08);
  border: 1px solid rgba(102, 112, 132, 0.12);
  opacity: 0.82;
  color: #667084;
  font-size: 22rpx;
  font-weight: 700;
}

.unit-selector__overlay {
  position: fixed;
  inset: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(15, 23, 42, 0.22);
}

.unit-selector {
  width: 100%;
  max-width: 640rpx;
  max-height: 62vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 42rpx rgba(37, 49, 71, 0.18);
  box-sizing: border-box;
}

.unit-selector__header {
  flex: none;
  padding-bottom: 8rpx;
}

.unit-selector__title {
  font-size: 38rpx;
  font-weight: 800;
  color: #182234;
}

.unit-selector__input {
  width: 100%;
  height: 88rpx;
  margin-top: 18rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #fafbfe;
  border: 1px solid #edf0f4;
  font-size: 28rpx;
  color: #27323f;
}

.unit-selector__list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  max-height: 40vh;
}

.unit-selector__list-inner {
  display: grid;
  gap: 12rpx;
}

.unit-selector__option {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #27323f;
  font-size: 32rpx;
  font-weight: 700;
}

.unit-selector__option--active {
  background: rgba(197, 106, 61, 0.1);
  color: var(--brand);
}

.unit-selector__empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #7a808d;
  font-size: 28rpx;
  text-align: center;
}

.unit-selector__footer {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.unit-selector__cancel,
.unit-selector__confirm {
  flex: 1;
  height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.unit-selector__cancel {
  background: #edf1f6;
  color: #27323f;
}

.unit-selector__confirm {
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
}

.description-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.description-head__label {
  font-size: 28rpx;
  font-weight: 700;
  color: #27323f;
}

.description-head__count {
  font-size: 22rpx;
  color: #8c95a2;
}

.field-textarea {
  padding: 18rpx 24rpx;
  line-height: 1.6;
}

.field-textarea--notes {
  min-height: 80rpx;
  height: 80rpx;
}

.detail-notes {
  margin-top: 10rpx;
  padding: 18rpx 24rpx;
  border-radius: 18rpx;
  background: #fafbfe;
  border: 1px solid #edf0f4;
  font-size: 28rpx;
  line-height: 1.6;
  color: #27323f;
}

.delete-button {
  margin-top: 6rpx;
  width: auto;
  align-self: flex-start;
  --td-button-danger-outline-color: #d14b4b;
  --td-button-danger-outline-border-color: rgba(209, 75, 75, 0.4);
}

.bottom-actions {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 14rpx);
  display: flex;
  gap: 14rpx;
}

.footer-close-btn {
  width: 170rpx;
  --td-button-default-bg-color: #edf1f6;
  --td-button-default-color: #27323f;
  --td-button-default-border-color: transparent;
}

.footer-submit-btn {
  flex: 1;
  --td-button-primary-bg-color: var(--brand);
  --td-button-primary-active-bg-color: var(--brand-strong);
  --td-button-primary-border-color: var(--brand);
}

@media (max-width: 720rpx) {
  .detail-grid {
    grid-template-columns: 1fr;
  }

  .detail-pair-grid {
    grid-template-columns: 1fr;
  }
}
