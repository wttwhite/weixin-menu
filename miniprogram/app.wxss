@import "./styles/theme.wxss";

.container {
  box-sizing: border-box;
}

button {
  background: transparent;
  border: 0;
  border-radius: 999rpx;
  color: inherit;
  line-height: 1.2;
  padding: 0;
}

button::after {
  border: 0;
}

page {
  background: var(--page-bg);
  color: var(--text-primary);
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}
