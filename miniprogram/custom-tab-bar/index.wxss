.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0;
  pointer-events: none;
}

.tabbar-surface {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  padding: 14rpx 18rpx calc(env(safe-area-inset-bottom) + 10rpx);
  border-radius: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), var(--surface-bg, rgba(255, 255, 255, 0.96)));
  box-shadow: var(--shadow-soft, 0 -6rpx 20rpx rgba(37, 49, 71, 0.08));
  border-top: 1rpx solid var(--border-soft, rgba(210, 218, 230, 0.9));
  pointer-events: auto;
  backdrop-filter: blur(12rpx);
}

.tabbar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 0 6rpx;
  color: var(--text-secondary, #6b7280);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  color: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 180ms ease;
}

.tabbar-label {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
  color: inherit;
}

.tabbar-item--active {
  color: var(--brand, #4f7d8a);
}

.tabbar-item--active .tabbar-label {
  font-weight: 900;
}
