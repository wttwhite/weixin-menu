.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 14rpx calc(env(safe-area-inset-bottom) + 12rpx);
  pointer-events: none;
}

.tabbar-surface {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 10rpx;
  padding: 14rpx 12rpx 0;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), var(--surface-bg, rgba(255, 255, 255, 0.96)));
  box-shadow: var(--shadow-soft, 0 -6rpx 20rpx rgba(37, 49, 71, 0.08));
  border: 1rpx solid var(--border-soft, rgba(210, 218, 230, 0.9));
  pointer-events: auto;
  backdrop-filter: blur(18rpx);
}

.tabbar-item {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 12rpx;
  color: var(--text-tertiary, #7f8795);
}

.tabbar-item__glow {
  position: absolute;
  inset: 6rpx 10rpx 18rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at center, var(--brand-strong, rgba(163, 78, 36, 0.18)) 0%, transparent 70%);
  opacity: 0;
  transform: scale(0.88);
  transition: opacity 180ms ease, transform 180ms ease;
}

.tabbar-item__pill {
  position: relative;
  z-index: 1;
  width: 100%;
  min-height: 84rpx;
  box-sizing: border-box;
  padding: 10rpx 8rpx 12rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: transparent;
  border: 1rpx solid transparent;
  transition: background 180ms ease, border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
}

.tabbar-item--active .tabbar-item__glow {
  opacity: 1;
  transform: scale(1);
}

.tabbar-item--active .tabbar-item__pill {
  background: linear-gradient(180deg, var(--surface-bg, rgba(255, 255, 255, 0.98)), var(--surface-muted, rgba(255, 255, 255, 0.72)));
  border-color: var(--border-soft, rgba(210, 218, 230, 0.9));
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-4rpx);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
  transition: transform 180ms ease, filter 180ms ease;
}

.tabbar-item--active .tabbar-icon {
  transform: scale(1.04);
  filter: drop-shadow(0 6rpx 12rpx rgba(0, 0, 0, 0.12));
}

.tabbar-label {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
  color: inherit;
}

.tabbar-item--active .tabbar-label {
  color: var(--brand, #c56a3d);
}
