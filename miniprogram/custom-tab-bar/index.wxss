.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0;
  pointer-events: none;
}

.tabbar-surface {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  padding: 14rpx 18rpx calc(env(safe-area-inset-bottom) + 10rpx);
  border-radius: 0;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -6rpx 20rpx rgba(37, 49, 71, 0.08);
  border-top: 1rpx solid rgba(210, 218, 230, 0.9);
  pointer-events: auto;
}

.tabbar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 0 6rpx;
  color: #7f8795;
}

.tabbar-item--active {
  color: var(--brand, #c56a3d);
}

.tabbar-icon {
  width: 48rpx;
  height: 48rpx;
}

.tabbar-label {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
}
