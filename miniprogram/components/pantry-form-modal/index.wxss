@import "../../pages/pantry-edit/index.wxss";

.pantry-form-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 72rpx 20rpx calc(env(safe-area-inset-bottom) + 150rpx);
  background: rgba(12, 24, 18, 0.3);
  backdrop-filter: blur(6rpx);
  box-sizing: border-box;
}

.pantry-form-modal {
  width: 100%;
  height: 100%;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 40rpx;
  padding: 28rpx 24rpx 24rpx;
  background: rgba(247, 250, 248, 0.98);
  box-shadow: 0 24rpx 44rpx rgba(37, 49, 71, 0.18);
}

.pantry-form-modal__header {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 18rpx;
}

.pantry-form-modal__title {
  font-size: 34rpx;
  font-weight: 900;
  color: #12213a;
}

.pantry-form-modal__close-icon,
.category-selector__close,
.unit-selector__close {
  width: 56rpx;
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted, #f2f4f8);
  color: var(--text-secondary, #667084);
  font-size: 26rpx;
  font-weight: 700;
}

.pantry-form-modal__body {
  flex: 1;
  min-height: 0;
  height: auto;
  overflow-y: auto;
}

.pantry-form-modal__body-content {
  padding-right: 4rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.pantry-form-modal__footer {
  position: relative;
  left: auto;
  right: auto;
  bottom: auto;
  display: flex;
  gap: 14rpx;
  flex: none;
  margin-top: 12rpx;
  padding-top: 14rpx;
  background: linear-gradient(180deg, rgba(247, 250, 248, 0) 0%, rgba(247, 250, 248, 0.98) 24%);
}

.pantry-form-modal__close,
.pantry-form-modal__submit {
  min-height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.pantry-form-modal__close {
  width: 170rpx;
  background: #edf1f6;
  color: #27323f;
}

.pantry-form-modal__submit {
  flex: 1;
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
}

.category-picker {
  flex: 1;
}

.category-picker__value {
  margin-top: 0;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.pantry-form-modal .field-input,
.pantry-form-modal .category-picker__value {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: #fff;
}

.pantry-form-modal .field-input--readonly {
  color: #667084;
  background: #f3f5f8;
}

.pantry-form-modal .field-textarea {
  background: #fff;
}

.pantry-form-modal .quantity-stepper {
  height: 74rpx;
  box-sizing: border-box;
  background: #fff;
}

.pantry-form-modal .stepper-button,
.pantry-form-modal .stepper-value {
  height: 72rpx;
  background: #fff;
}

.pantry-form-modal .stepper-button {
  width: 72rpx;
  min-width: 72rpx;
}

.pantry-form-modal .field-label {
  margin-top: 18rpx;
  font-size: 24rpx;
}

.pantry-form-modal .field-label--tight {
  margin-top: 0;
}

.field-picker-row {
  margin-top: 10rpx;
}

.field-picker-row .field-input,
.field-picker-row .date-row__picker,
.field-picker-row .category-picker__value {
  margin-top: 0;
}

.pantry-form-modal .date-row__picker .field-input {
  margin-top: 0;
}

.category-picker__text {
  flex: 1;
  min-width: 0;
}

.category-picker__actions {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 14rpx;
}

.category-picker__value--placeholder {
  color: #b6bdc8;
}

.category-picker__arrow {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-right: 3rpx solid #a1a8b3;
  border-bottom: 3rpx solid #a1a8b3;
  transform: rotate(45deg);
}

.category-selector__overlay {
  position: fixed;
  inset: 0;
  z-index: 90;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(15, 23, 42, 0.22);
}

.category-selector {
  width: 100%;
  max-width: 640rpx;
  max-height: 62vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 28rpx;
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 42rpx rgba(37, 49, 71, 0.18);
  box-sizing: border-box;
}

.category-selector__header {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.category-selector__title,
.unit-selector__title {
  font-size: 34rpx;
  font-weight: 800;
  color: #182234;
}

.category-selector__list {
  flex: 1;
  min-height: 0;
  margin-top: 18rpx;
  max-height: 52vh;
}

.category-selector__list-inner {
  display: grid;
  gap: 12rpx;
}

.category-selector__item {
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #27323f;
  font-size: 32rpx;
  font-weight: 700;
}

.category-selector__item--active {
  background: var(--surface-muted, #f3f4f7);
  color: var(--brand);
}

.field-clear--inline {
  position: static;
  right: auto;
  top: auto;
  transform: none;
  z-index: 1;
  flex: none;
}

.category-selector__empty {
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #f7f9fd;
  color: #7a808d;
  font-size: 28rpx;
  text-align: center;
}
