@import "../../pages/pantry-edit/index.wxss";

.pantry-form-modal__overlay {
  position: fixed;
  inset: 0;
  z-index: 80;
  padding: 72rpx 20rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(12, 24, 18, 0.3);
  backdrop-filter: blur(6rpx);
  box-sizing: border-box;
}

.pantry-form-modal {
  max-height: 86vh;
  overflow-y: auto;
  border-radius: 40rpx;
  padding: 28rpx 24rpx 24rpx;
  background: rgba(247, 250, 248, 0.98);
  box-shadow: 0 24rpx 44rpx rgba(37, 49, 71, 0.18);
}

.pantry-form-modal__title {
  margin-bottom: 18rpx;
  font-size: 58rpx;
  font-weight: 900;
  color: #12213a;
}

.bottom-actions {
  position: sticky;
  left: auto;
  right: auto;
  bottom: 0;
  margin-top: 6rpx;
  padding-top: 14rpx;
  background: linear-gradient(180deg, rgba(247, 250, 248, 0) 0%, rgba(247, 250, 248, 0.98) 24%);
}

.pantry-form-modal__close,
.pantry-form-modal__submit {
  min-height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.pantry-form-modal__close {
  width: 170rpx;
  background: #edf1f6;
  color: #27323f;
}

.pantry-form-modal__submit {
  flex: 1;
  background: linear-gradient(135deg, var(--brand), var(--brand-strong));
  color: #fff;
}
