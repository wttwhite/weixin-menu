.recipe-card {
  display: flex;
  gap: 18rpx;
  border-radius: 28rpx;
  padding: 28rpx;
  background: #fff;
  box-shadow: var(--shadow-soft);
}

.recipe-card__media {
  position: relative;
  width: 172rpx;
  min-width: 172rpx;
}

.recipe-card__cover {
  width: 172rpx;
  height: 172rpx;
  border-radius: 24rpx;
  background: #f2f4f8;
}

.recipe-card__cover--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(180deg, rgba(207, 147, 91, 0.82), rgba(148, 85, 42, 0.9)),
    #f2f4f8;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
}

.recipe-card__category {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(21, 14, 9, 0.62);
  color: #fff;
  font-size: 22rpx;
}

.recipe-card__body {
  flex: 1;
  min-width: 0;
}

.recipe-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.recipe-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.recipe-card__favorite {
  font-size: 22rpx;
  color: #9c5d10;
  background: #fff1de;
  border-radius: 999rpx;
  padding: 8rpx 12rpx;
}

.recipe-card__stars {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #c9781d;
  letter-spacing: 2rpx;
}

.recipe-card__meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.recipe-card__summary {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.recipe-card__metric {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: var(--text-tertiary);
}

.recipe-card__tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.recipe-card__tag-summary {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.recipe-card__edit {
  margin-top: 20rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--surface-bg);
  color: var(--text-secondary);
  font-size: 24rpx;
}
