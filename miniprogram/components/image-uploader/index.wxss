.uploader {
  display: grid;
  gap: 14rpx;
}

.uploader__label {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.uploader__action-row {
  display: flex;
  gap: 16rpx;
}

.uploader__entry {
  flex: 1;
  height: 180rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 2rpx dashed #dce4f2;
  background: #f7f9fd;
}

.uploader__entry--camera {
  background: rgba(197, 106, 61, 0.08);
  border-color: rgba(197, 106, 61, 0.3);
}

.uploader__entry--album {
  background: rgba(197, 106, 61, 0.04);
  border-color: rgba(197, 106, 61, 0.2);
}

.uploader__entry--hover {
  opacity: 0.92;
}

.uploader__entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #fff;
  background: var(--brand, #c56a3d);
}

.uploader__entry--album .uploader__entry-icon {
  background: var(--brand-strong, #a34e24);
}

.uploader__entry-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #4a5565;
}

.uploader__hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.uploader__list {
  display: grid;
  gap: 12rpx;
}

.uploader__item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #fff;
}

.uploader__image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f2f4f8;
}

.uploader__meta {
  flex: 1;
  display: grid;
  gap: 10rpx;
}

.uploader__status {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.uploader__remove {
  width: 140rpx;
  min-height: 58rpx;
  border-radius: 12rpx;
  background: #f6ecec;
  color: #b44343;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
