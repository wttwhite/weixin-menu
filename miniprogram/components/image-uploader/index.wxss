.uploader {
  display: grid;
  gap: 14rpx;
}

.uploader__label {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.uploader__list {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.uploader__item {
  position: relative;
  min-width: 0;
  aspect-ratio: 4 / 3;
  border-radius: 18rpx;
  border: 3rpx solid transparent;
  overflow: hidden;
  background: #f7f9fd;
}

.uploader__item--cover {
  border-color: var(--brand, #43a047);
}

.uploader__image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f2f4f8;
}

.uploader__cover-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: var(--brand, #43a047);
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.uploader__actions-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 6rpx 8rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.68), rgba(0, 0, 0, 0));
}

.uploader__overlay-btn {
  min-width: 54rpx;
  min-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.94);
  color: var(--brand, #43a047);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  white-space: nowrap;
}

.uploader__overlay-btn--delete {
  color: #ef4444;
}

.uploader__entry {
  min-width: 0;
  aspect-ratio: 4 / 3;
  min-height: 112rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 2rpx dashed var(--border-soft, #dce4f2);
  background: var(--surface-muted, #f3f4f7);
}

.uploader__entry--camera {
  background: #eef6ff;
  border-color: rgba(59, 130, 246, 0.28);
}

.uploader__entry--album {
  background: var(--surface-muted, #f3f4f7);
  border-color: var(--border-soft, #edf1f5);
}

.uploader__entry--hover {
  opacity: 0.92;
}

.uploader__entry-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  line-height: 1;
  color: #fff;
  background: var(--brand, #43a047);
}

.uploader__entry--camera .uploader__entry-icon {
  transform: translateY(-2rpx);
  background: #2563eb;
  font-size: 22rpx;
}

.uploader__entry--album .uploader__entry-icon {
  background: var(--brand, #43a047);
}

.uploader__entry-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #4a5565;
}

.uploader__hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}
